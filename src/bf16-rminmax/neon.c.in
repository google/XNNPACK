$assert BATCH_TILE % 8 == 0
$assert BATCH_TILE >= 8
$SIMD_TILE = BATCH_TILE // 8
$assert ACCUMULATORS <= SIMD_TILE
$assert OP in ["MAX", "MIN", "MINMAX"]
#include <arm_neon.h>
#include <assert.h>
#include <stddef.h>
#include <stdint.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/microparams.h"
#include "src/xnnpack/reduce.h"


$ACC_SUFFIX = "" if ACCUMULATORS == 1 else "_acc%d" % ACCUMULATORS
$EMIT_MIN = "MIN" in OP
$EMIT_MAX = "MAX" in OP
$MAX_POS = 1 if OP == "MINMAX" else 0
void xnn_bf16_r${OP.lower()}_ukernel__neon_u${BATCH_TILE}${ACC_SUFFIX}(
    size_t batch,
    const xnn_bfloat16* input,
    xnn_bfloat16* output,
    const struct xnn_bf16_default_params* restrict params) XNN_OOB_READS
{
  assert(batch != 0);
  assert(batch % sizeof(uint16_t) == 0);
  assert(input != NULL);
  assert(output != NULL);

  const uint16_t* i = (const uint16_t*) input;
  uint16_t* o = (uint16_t*) output;

  const uint16x8_t vsign_mask = vdupq_n_u16(UINT16_C(0x7FFF));

  $if EMIT_MIN:
    int16x8_t vmin0 = vreinterpretq_s16_u16(vld1q_dup_u16(o));
    vmin0 = veorq_s16(vmin0, vreinterpretq_s16_u16(vandq_u16(vreinterpretq_u16_s16(vshrq_n_s16(vmin0, 15)), vsign_mask)));
  $if EMIT_MAX:
    int16x8_t vmax0 = vreinterpretq_s16_u16(vld1q_dup_u16((uint16_t*)((uintptr_t) o + ${MAX_POS} * sizeof(uint16_t))));
    vmax0 = veorq_s16(vmax0, vreinterpretq_s16_u16(vandq_u16(vreinterpretq_u16_s16(vshrq_n_s16(vmax0, 15)), vsign_mask)));
  $if BATCH_TILE > 8:
    $for A in range(1, ACCUMULATORS):
      $if EMIT_MIN:
        int16x8_t vmin${A} = vmin0;
      $if EMIT_MAX:
        int16x8_t vmax${A} = vmax0;
    for (; batch >= ${BATCH_TILE} * sizeof(uint16_t); batch -= ${BATCH_TILE} * sizeof(uint16_t)) {
      $for N in range(SIMD_TILE):
        const int16x8_t vi${N} = vreinterpretq_s16_u16(vld1q_u16(i)); i += 8;

      $for N in range(SIMD_TILE):
        const int16x8_t vt${N} = veorq_s16(vi${N}, vreinterpretq_s16_u16(vandq_u16(vreinterpretq_u16_s16(vshrq_n_s16(vi${N}, 15)), vsign_mask)));

      $for N in range(SIMD_TILE):
        $if $EMIT_MIN:
          vmin${N % ACCUMULATORS} = vminq_s16(vmin${N % ACCUMULATORS}, vt${N});
        $if $EMIT_MAX:
          vmax${N % ACCUMULATORS} = vmaxq_s16(vmax${N % ACCUMULATORS}, vt${N});
    }
    $if ACCUMULATORS > 1:
      $ACC_SLICE = 1
      $while ACC_SLICE < ACCUMULATORS:
        $for A in range(0, ACCUMULATORS, ACC_SLICE * 2):
          $if A + ACC_SLICE < ACCUMULATORS:
            $if $EMIT_MIN:
              vmin${A} = vminq_s16(vmin${A}, vmin${A + ACC_SLICE});
            $if $EMIT_MAX:
              vmax${A} = vmaxq_s16(vmax${A}, vmax${A + ACC_SLICE});
        $ACC_SLICE *= 2
  for (; batch >= 8 * sizeof(uint16_t); batch -= 8 * sizeof(uint16_t)) {
    const int16x8_t vi = vreinterpretq_s16_u16(vld1q_u16(i)); i += 8;
    const int16x8_t vt = veorq_s16(vi, vreinterpretq_s16_u16(vandq_u16(vreinterpretq_u16_s16(vshrq_n_s16(vi, 15)), vsign_mask)));
    $if $EMIT_MIN:
      vmin0 = vminq_s16(vmin0, vt);
    $if $EMIT_MAX:
      vmax0 = vmaxq_s16(vmax0, vt);
  }
  $if $EMIT_MIN:
    int16x4_t vmin_lo = vmin_s16(vget_low_s16(vmin0), vget_high_s16(vmin0));
  $if $EMIT_MAX:
    int16x4_t vmax_lo = vmax_s16(vget_low_s16(vmax0), vget_high_s16(vmax0));

  if (XNN_UNLIKELY(batch != 0)) {
    const int16x8_t vi = vreinterpretq_s16_u16(vld1q_u16(i));
    const int16x8_t vt = veorq_s16(vi, vreinterpretq_s16_u16(vandq_u16(vreinterpretq_u16_s16(vshrq_n_s16(vi, 15)), vsign_mask)));
    int16x4_t vt_lo = vget_low_s16(vt);
    if (batch & (4 * sizeof(uint16_t))) {
      $if $EMIT_MIN:
        vmin_lo = vmin_s16(vmin_lo, vt_lo);
      $if $EMIT_MAX:
        vmax_lo = vmax_s16(vmax_lo, vt_lo);
      vt_lo = vget_high_s16(vt);
    }
    if (batch & (2 * sizeof(uint16_t))) {
      $if $EMIT_MIN:
        vmin_lo = vmin_s16(vmin_lo, vext_s16(vmin_lo, vt_lo, 2));
      $if $EMIT_MAX:
        vmax_lo = vmax_s16(vmax_lo, vext_s16(vmax_lo, vt_lo, 2));
      vt_lo = vext_s16(vt_lo, vt_lo, 2);
    }
    if (batch & (1 * sizeof(uint16_t))) {
      $if $EMIT_MIN:
        vmin_lo = vmin_s16(vmin_lo, vext_s16(vmin_lo, vt_lo, 1));
      $if $EMIT_MAX:
        vmax_lo = vmax_s16(vmax_lo, vext_s16(vmax_lo, vt_lo, 1));
    }
  }
  $if $EMIT_MIN:
    #if XNN_ARCH_ARM64
      int16_t vmin_s = vminv_s16(vmin_lo);
    #else
      vmin_lo = vpmin_s16(vmin_lo, vmin_lo);
      vmin_lo = vpmin_s16(vmin_lo, vmin_lo);
      int16_t vmin_s = vget_lane_s16(vmin_lo, 0);
    #endif
    o[0] = (uint16_t)(vmin_s ^ ((vmin_s >> 15) & 0x7FFF));
  $if $EMIT_MAX:
    #if XNN_ARCH_ARM64
      int16_t vmax_s = vmaxv_s16(vmax_lo);
    #else
      vmax_lo = vpmax_s16(vmax_lo, vmax_lo);
      vmax_lo = vpmax_s16(vmax_lo, vmax_lo);
      int16_t vmax_s = vget_lane_s16(vmax_lo, 0);
    #endif
    o[${MAX_POS}] = (uint16_t)(vmax_s ^ ((vmax_s >> 15) & 0x7FFF));
}
