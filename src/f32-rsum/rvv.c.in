$assert LMUL in [1, 2, 4, 8]
#include <assert.h>

#include <xnnpack/common.h>
#include <xnnpack/reduce.h>
#include <riscv_vector.h>

void xnn_f32_rsum_ukernel__rvv_u${LMUL}v(
    size_t batch,
    const float* input,
    float* output,
    const union xnn_f32_scale_params params[restrict XNN_MIN_ELEMENTS(1)])
{
  assert(batch != 0);
  assert(batch % sizeof(float) == 0);
  assert(input != NULL);
  assert(output != NULL);

  batch >>= XNN_LOG2_SIZEOF_FLOAT;
  int32_t n = __riscv_vsetvl_e32m1(batch);
  vfloat32m1_t acc_f32v = __riscv_vfmv_s_f_f32m1(0.f, n);
  $if LMUL == 1 or LMUL == 2:
    n = __riscv_vsetvl_e32m${LMUL}(batch);
    int32_t n_sum = __riscv_vsetvl_e32m${LMUL}(batch);
    vfloat32m${LMUL}_t sum_f32v = __riscv_vfmv_s_f_f32m${LMUL}(0.f, n_sum);
    if (batch >= n * 8) {
      for (; batch >= n * 8; batch -= n * 8) {
        vfloat32m${LMUL}_t in0_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in1_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in2_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in3_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in4_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in5_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in6_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in7_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t sum0_f32v = __riscv_vfadd_vv_f32m${LMUL}(in0_f32v, in1_f32v, n);
        vfloat32m${LMUL}_t sum1_f32v = __riscv_vfadd_vv_f32m${LMUL}(in2_f32v, in3_f32v, n);
        vfloat32m${LMUL}_t sum2_f32v = __riscv_vfadd_vv_f32m${LMUL}(in4_f32v, in5_f32v, n);
        vfloat32m${LMUL}_t sum3_f32v = __riscv_vfadd_vv_f32m${LMUL}(in6_f32v, in7_f32v, n);
        sum0_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum0_f32v, sum1_f32v, n);
        sum2_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum2_f32v, sum3_f32v, n);
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, sum0_f32v, n);
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, sum2_f32v, n);
      }
    }
    if (batch >= n * 4) {
      for (; batch >= n * 4; batch -= n * 4) {
        vfloat32m${LMUL}_t in0_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in1_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in2_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in3_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t sum0_f32v = __riscv_vfadd_vv_f32m${LMUL}(in0_f32v, in1_f32v, n);
        vfloat32m${LMUL}_t sum1_f32v = __riscv_vfadd_vv_f32m${LMUL}(in2_f32v, in3_f32v, n);
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, sum0_f32v, n);
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, sum1_f32v, n);
      }
    }
    if (batch > 0) {
      for (; batch > 0; batch -= n) {
        n = __riscv_vsetvl_e32m${LMUL}(batch);
        vfloat32m${LMUL}_t in_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, in_f32v, n);
      }
    }
    vfloat32m${LMUL}_t out_f32v = __riscv_vfmul_vf_f32m${LMUL}(sum_f32v, params->scalar.scale, n_sum);
    acc_f32v = __riscv_vfredosum_vs_f32m${LMUL}_f32m1(out_f32v, acc_f32v, n_sum);
  $elif LMUL == 4:
    n = __riscv_vsetvl_e32m${LMUL}(batch);
    int32_t n_sum = __riscv_vsetvl_e32m${LMUL}(batch);
    vfloat32m${LMUL}_t sum_f32v = __riscv_vfmv_s_f_f32m${LMUL}(0.f, n_sum);
    if (batch >= n * 4) {
      for (; batch >= n * 4; batch -= n * 4) {
        vfloat32m${LMUL}_t in0_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in1_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in2_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in3_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t sum0_f32v = __riscv_vfadd_vv_f32m${LMUL}(in0_f32v, in1_f32v, n);
        vfloat32m${LMUL}_t sum1_f32v = __riscv_vfadd_vv_f32m${LMUL}(in2_f32v, in3_f32v, n);
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, sum0_f32v, n);
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, sum1_f32v, n);
      }
    }
    if (batch > 0) {
      for (; batch > 0; batch -= n) {
        n = __riscv_vsetvl_e32m${LMUL}(batch);
        vfloat32m${LMUL}_t in_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, in_f32v, n);
      }
    }
    vfloat32m${LMUL}_t out_f32v = __riscv_vfmul_vf_f32m${LMUL}(sum_f32v, params->scalar.scale, n_sum);
    acc_f32v = __riscv_vfredosum_vs_f32m${LMUL}_f32m1(out_f32v, acc_f32v, n_sum);
  $elif LMUL == 8:
    n = __riscv_vsetvl_e32m${LMUL}(batch);
    int32_t n_sum = __riscv_vsetvl_e32m${LMUL}(batch);
    vfloat32m${LMUL}_t sum_f32v = __riscv_vfmv_s_f_f32m${LMUL}(0.f, n_sum);
    if (batch >= n * 2) {
      for (; batch >= n * 2; batch -= n * 2) {
        vfloat32m${LMUL}_t in0_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        vfloat32m${LMUL}_t in1_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, in0_f32v, n);
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, in1_f32v, n);
      }
    }
    if (batch > 0) {
      for (; batch > 0; batch -= n) {
        n = __riscv_vsetvl_e32m${LMUL}(batch);
        vfloat32m${LMUL}_t in_f32v = __riscv_vle32_v_f32m${LMUL}(input, n); input += n;
        sum_f32v = __riscv_vfadd_vv_f32m${LMUL}(sum_f32v, in_f32v, n);
      }
    }
    vfloat32m${LMUL}_t out_f32v = __riscv_vfmul_vf_f32m${LMUL}(sum_f32v, params->scalar.scale, n_sum);
    acc_f32v = __riscv_vfredosum_vs_f32m${LMUL}_f32m1(out_f32v, acc_f32v, n_sum);
  __riscv_vse32_v_f32m1(output, acc_f32v, 1);
}
