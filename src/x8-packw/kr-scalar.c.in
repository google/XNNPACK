$assert DATATYPE in ["QS8", "QS4", "QC4UW"]
$assert IZP in [0, 128]
$if DATATYPE in ["QS4", "QC4UW"]:
  $assert KR == 8
$else:
  $assert KR > 1
#include <assert.h>
#include <stddef.h>
#include <stdint.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/microparams.h"
#include "src/xnnpack/packw.h"
$if DATATYPE in ["QS4", "QC4UW"]:
  #include "src/xnnpack/unaligned.h"

$WTYPE = {"QS8": "int8_t", "QS4": "uint8_t", "QC4UW": "uint8_t"}[DATATYPE]
$OUTTYPE = {"QS8": "int8_t", "QS4": "uint8_t", "QC4UW": "uint8_t"}[DATATYPE]
$PACKEDWTYPE = {"QS8": "int8_t", "QS4": "void", "QC4UW": "void"}[DATATYPE]
$BTYPE = "int32_t"
$SCALETYPE = {"QS8": "void", "QS4": "float", "QC4UW": "float"}[DATATYPE]
$PARAMTYPE = {"QS8": "void", "QS4": "struct xnn_qs8_qc4w_packing_params", "QC4UW": "struct xnn_qs8_qc4w_packing_params"}[DATATYPE]
$DATATYPE_SPEC = {"QS8": "qs8_to_qu8" if IZP == 128 else "qs8", "QS4": "qs8_to_qu8_qc4w" if IZP == 128 else "qs8_qc4w", "QC4UW": "qs8_to_qu8_qc4uw" if IZP == 128 else "qs8_qc4uw"}[DATATYPE]
$if DATATYPE in ["QS4", "QC4UW"]:
  // Sign extend 4-bit to 8-bit
  inline static int8_t sign_extend_int4(uint8_t v) {
    return (int8_t)(v << 4) >> 4;
  }

  $#
void xnn_${DATATYPE_SPEC}_packw_gemm_goi_ukernel_x${NR}c${KR}__scalar(
  size_t g,
  size_t nc,
  size_t kc,
  size_t nr,
  size_t kr,
  size_t sr,
  const ${WTYPE}* weights,
  const ${BTYPE}* bias,
  const ${SCALETYPE}* scale,
  ${PACKEDWTYPE}* packed_weights,
  size_t extra_bytes,
  const ${PARAMTYPE}* params)
{
  assert(g != 0);
  assert(nc != 0);
  assert(kc != 0);
  assert(nr == ${NR});
  assert(kr == ${KR});
  assert(sr == 1);
  assert(weights != NULL);
  assert(packed_weights != NULL);
  $if DATATYPE in ["QS4", "QC4UW"]:
    assert(params != NULL);
    assert(params->kernel_zero_point == 8 || params->kernel_zero_point == 0);
    assert(kc % 2 == 0);

  ${OUTTYPE}* out = (${OUTTYPE}*) packed_weights;
  const ${BTYPE}* b = (const ${BTYPE}*) bias;
  $if DATATYPE == "QS8":
    const uint32_t izp = (uint32_t) (params ? (((const struct xnn_qs8_packw_params*) params)->input_zero_point + ${IZP}): ${IZP});

    do {
      // NC main loop multiple of ${NR}
      const ${OUTTYPE}* w0 = (const ${OUTTYPE}*) weights;
      size_t n = nc;
      for (;n >= ${NR}; n -= ${NR}) {
        int32_t* packed_b = (int32_t*) out;
        if XNN_LIKELY(b != NULL) {
          $for N in range(NR):
            ((int32_t*) out)[${N}] = b[${N}];
          b += ${NR};
        } else {
          $for N in range(NR):
            ((int32_t*) out)[${N}] = 0;
        }
        out += ${NR} * sizeof(int32_t);

        $for N in range(1, NR):
          const ${OUTTYPE}* w${N} = w${N-1} + kc;
        $for N in range(NR):
          uint32_t ksum${N} = 0;

        // KC main loop multiple of ${NR}x${KR}
        size_t k = kc;
        for (; k >= ${KR}; k -= ${KR}) {
          $for N in range(NR):
            $for K in range(KR):
              const ${OUTTYPE} v${N}x${K} = w${N}[${K}];
            $for K in range(KR):
              ksum${N} += (uint32_t) v${N}x${K};
            $for K in range(KR):
              out[${N*KR+K}] = v${N}x${K};
            w${N} += ${KR};
          out += ${NR*KR};
        }

        // KC remainder of 1..${KR-1}
        if (k != 0) {
          assert(k >= 1 && k <= ${KR-1});
          $for N in range(NR):
            const ${OUTTYPE} v${N}x0 = w${N}[0];
            $for K in range(1, KR):
              const ${OUTTYPE} v${N}x${K} = ${K} < k ? w${N}[${K}] : 0;
            ksum${N} += (uint32_t) v${N}x0;
            $for K in range(1, KR):
              ksum${N} += (uint32_t) v${N}x${K};
            out[${N*KR}] = v${N}x0;
            $for K in range(1, KR):
              out[${N*KR+K}] = v${N}x${K};
            w${N} += k;
          out += ${NR*KR};
        }

        $for N in range(NR):
          packed_b[${N}] -= ksum${N} * izp;
        out = (${OUTTYPE}*) ((uintptr_t) out + extra_bytes);
        w0 = w${NR-1};
      }

      // NC remainder (1..${NR-1})
      if XNN_UNLIKELY(n != 0) {
        int32_t* packed_b = (int32_t*) out;
        if XNN_LIKELY(b != NULL) {
          size_t nb = n;
          do {
            *((${BTYPE}*) out) = *b++;
            out += sizeof(${BTYPE});
          } while (--nb != 0);
        } else {
          size_t nb = n;
          do {
            *((${BTYPE}*) out) = 0;
            out += sizeof(${BTYPE});
          } while (--nb != 0);
        }
        out += (${NR} - n) * sizeof(${BTYPE});

        $if NR > 2:
          // NR remainder has less than ${NR} rows so last row is not loaded
        $for N in range(1, NR-1):
          const ${OUTTYPE}* w${N} = w${N-1} + kc;
          $if N % 2 == 0:
            if XNN_UNPREDICTABLE(n <= ${N}) {
              w${N} = w${N-1};
            }
          $else:
            if XNN_UNPREDICTABLE(n < ${N+1}) {
              w${N} = w${N-1};
            }

        $for N in range(NR-1):
          uint32_t ksum${N} = 0;

        // KC main loop multiple of ${NR}x${KR}
        size_t k = kc;
        for (; k >= ${KR}; k -= ${KR}) {
          $for N in range(NR-1):
            $for K in range(KR):
              const ${OUTTYPE} v${N}x${K} = w${N}[${K}];
            $for K in range(KR):
              ksum${N} += (uint32_t) v${N}x${K};
            $for K in range(KR):
              out[${N*KR+K}] = v${N}x${K};
            w${N} += ${KR};
          out += ${NR*KR};
        }

        // KC remainder of 1..${KR-1}
        if (k != 0) {
          assert(k >= 1 && k <= ${KR-1});
          $for N in range(NR-1):
            const ${OUTTYPE} v${N}x0 = w${N}[0];
            $for K in range(1, KR):
              const ${OUTTYPE} v${N}x${K} = ${K} < k ? w${N}[${K}] : 0;
            ksum${N} += (uint32_t) v${N}x0;
            $for K in range(1, KR):
              ksum${N} += (uint32_t) v${N}x${K};
            out[${N*KR}] = v${N}x0;
            $for K in range(1, KR):
              out[${N*KR+K}] = v${N}x${K};
            w${N} += k;
          $for N in range((NR - 1)*KR, NR*KR, 1):
            out[${N}] = 0;
          out += ${NR*KR};
        }

        $for N in range(NR-1):
          packed_b[${N}] -= ksum${N} * izp;
        out = (${OUTTYPE}*) ((uintptr_t) out + extra_bytes);
      }
      weights += nc * kc;
    } while (--g != 0);
  $else:
    // QS4 or QC4UW
    $BIAS_SCALE = " * 16" if DATATYPE == "QS4" else ""
    $KSUM_SCALE = " * 16" if DATATYPE == "QS4" else ""
    $XOR_ON_ZP0 = (DATATYPE == "QC4UW")
    $XOR_ON_ZPNZ = (DATATYPE == "QS4")

    const size_t mock_kc = kc >> 1; // kc in bytes (each byte has 2 weights)
    const uint32_t izp = (uint32_t) params->input_zero_point + ${IZP};
    const uint32_t kernel_zero_point = (uint32_t) params->kernel_zero_point;

    do {
      // NC main loop multiple of ${NR}
      const uint8_t* w0 = weights;
      size_t n = nc;
      for (; n >= ${NR}; n -= ${NR}) {
        int32_t* packed_b = (int32_t*) out;
        if (b != NULL) {
          for (size_t i = 0; i < ${NR}; ++i) {
            packed_b[i] = b[i]${BIAS_SCALE};
          }
          b += ${NR};
        } else {
          for (size_t i = 0; i < ${NR}; ++i) {
            packed_b[i] = 0;
          }
        }
        out += ${NR} * sizeof(int32_t);

        $for N in range(1, NR):
          const uint8_t* w${N} = w${N-1} + mock_kc;

        $for N in range(NR):
          int32_t ksum${N} = 0;

        // KC main loop multiple of ${KR} (which is 8)
        size_t k = mock_kc;
        for (; k >= 8; k -= 8) {
          $for N in range(NR):
            for (size_t i = 0; i < 8; ++i) {
              const uint8_t byte_lo = w${N}[i >> 1];
              const uint8_t byte_hi = w${N}[(i >> 1) + 4];
              uint8_t val_lo = (i & 1) ? (byte_lo >> 4) : (byte_lo & 0xF);
              uint8_t val_hi = (i & 1) ? (byte_hi >> 4) : (byte_hi & 0xF);

              if (kernel_zero_point == 0) {
                $if XOR_ON_ZP0:
                  const uint8_t kv = (val_lo | (val_hi << 4)) ^ 0x88;
                $else:
                  const uint8_t kv = val_lo | (val_hi << 4);
                out[${N} * 8 + i] = kv;
                ksum${N} += sign_extend_int4(val_lo) + sign_extend_int4(val_hi);
              } else {
                $if XOR_ON_ZPNZ:
                  const uint8_t kv = (val_lo | (val_hi << 4)) ^ 0x88;
                $else:
                  const uint8_t kv = val_lo | (val_hi << 4);
                out[${N} * 8 + i] = kv;
                ksum${N} += (int32_t)val_lo + (int32_t)val_hi - 16;
              }
            }
            w${N} += 8;
          out += ${NR} * 8;
        }

        // KC remainder of 1..7 bytes
        if (k != 0) {
          $for N in range(NR):
            uint8_t temp_w${N}[8];
            for (size_t i = 0; i < k; ++i) {
              temp_w${N}[i] = w${N}[i];
            }
            for (size_t i = k; i < 8; ++i) {
              temp_w${N}[i] = kernel_zero_point * 0x11;
            }

          $for N in range(NR):
            for (size_t i = 0; i < 8; ++i) {
              const uint8_t byte_lo = temp_w${N}[i >> 1];
              const uint8_t byte_hi = temp_w${N}[(i >> 1) + 4];
              uint8_t val_lo = (i & 1) ? (byte_lo >> 4) : (byte_lo & 0xF);
              uint8_t val_hi = (i & 1) ? (byte_hi >> 4) : (byte_hi & 0xF);

              if (kernel_zero_point == 0) {
                $if XOR_ON_ZP0:
                  const uint8_t kv = (val_lo | (val_hi << 4)) ^ 0x88;
                $else:
                  const uint8_t kv = val_lo | (val_hi << 4);
                out[${N} * 8 + i] = kv;
                ksum${N} += sign_extend_int4(val_lo) + sign_extend_int4(val_hi);
              } else {
                $if XOR_ON_ZPNZ:
                  const uint8_t kv = (val_lo | (val_hi << 4)) ^ 0x88;
                $else:
                  const uint8_t kv = val_lo | (val_hi << 4);
                out[${N} * 8 + i] = kv;
                ksum${N} += (int32_t)val_lo + (int32_t)val_hi - 16;
              }
            }
            w${N} += k;
          out += ${NR} * 8;
        }

        $for N in range(NR):
          packed_b[${N}] -= ksum${N} * izp${KSUM_SCALE};
        out = (uint8_t*) ((uintptr_t) out + extra_bytes);
        w0 = w${NR-1};
      }

      // NC remainder (1..${NR-1})
      if XNN_UNLIKELY(n != 0) {
        int32_t* packed_b = (int32_t*) out;
        if (b != NULL) {
          for (size_t i = 0; i < n; ++i) {
            packed_b[i] = b[i]${BIAS_SCALE};
          }
          b += n;
        } else {
          for (size_t i = 0; i < n; ++i) {
            packed_b[i] = 0;
          }
        }
        out += ${NR} * sizeof(int32_t);

        // Clamp weight pointers
        $for N in range(1, NR-1):
          const uint8_t* w${N} = w${N-1} + mock_kc;
          $if N % 2 == 0:
            if XNN_UNPREDICTABLE(n <= ${N}) {
              w${N} = w${N-1};
            }
          $else:
            if XNN_UNPREDICTABLE(n < ${N+1}) {
              w${N} = w${N-1};
            }

        $for N in range(NR-1):
          int32_t ksum${N} = 0;

        // KC main loop multiple of ${KR} (which is 8)
        size_t k = mock_kc;
        for (; k >= 8; k -= 8) {
          $for N in range(NR-1):
            for (size_t i = 0; i < 8; ++i) {
              const uint8_t byte_lo = w${N}[i >> 1];
              const uint8_t byte_hi = w${N}[(i >> 1) + 4];
              uint8_t val_lo = (i & 1) ? (byte_lo >> 4) : (byte_lo & 0xF);
              uint8_t val_hi = (i & 1) ? (byte_hi >> 4) : (byte_hi & 0xF);

              if (kernel_zero_point == 0) {
                $if XOR_ON_ZP0:
                  const uint8_t kv = (val_lo | (val_hi << 4)) ^ 0x88;
                $else:
                  const uint8_t kv = val_lo | (val_hi << 4);
                out[${N} * 8 + i] = kv;
                ksum${N} += sign_extend_int4(val_lo) + sign_extend_int4(val_hi);
              } else {
                $if XOR_ON_ZPNZ:
                  const uint8_t kv = (val_lo | (val_hi << 4)) ^ 0x88;
                $else:
                  const uint8_t kv = val_lo | (val_hi << 4);
                out[${N} * 8 + i] = kv;
                ksum${N} += (int32_t)val_lo + (int32_t)val_hi - 16;
              }
            }
            w${N} += 8;

          // Pad the remaining row(s)
          $for N in range(NR-1, NR):
            for (size_t i = 0; i < 8; ++i) {
              out[${N} * 8 + i] = 0;
            }
          out += ${NR} * 8;
        }

        // KC remainder of 1..7 bytes
        if (k != 0) {
          $for N in range(NR-1):
            uint8_t temp_w${N}[8];
            for (size_t i = 0; i < k; ++i) {
              temp_w${N}[i] = w${N}[i];
            }
            for (size_t i = k; i < 8; ++i) {
              temp_w${N}[i] = kernel_zero_point * 0x11;
            }

          $for N in range(NR-1):
            for (size_t i = 0; i < 8; ++i) {
              const uint8_t byte_lo = temp_w${N}[i >> 1];
              const uint8_t byte_hi = temp_w${N}[(i >> 1) + 4];
              uint8_t val_lo = (i & 1) ? (byte_lo >> 4) : (byte_lo & 0xF);
              uint8_t val_hi = (i & 1) ? (byte_hi >> 4) : (byte_hi & 0xF);

              if (kernel_zero_point == 0) {
                $if XOR_ON_ZP0:
                  const uint8_t kv = (val_lo | (val_hi << 4)) ^ 0x88;
                $else:
                  const uint8_t kv = val_lo | (val_hi << 4);
                out[${N} * 8 + i] = kv;
                ksum${N} += sign_extend_int4(val_lo) + sign_extend_int4(val_hi);
              } else {
                $if XOR_ON_ZPNZ:
                  const uint8_t kv = (val_lo | (val_hi << 4)) ^ 0x88;
                $else:
                  const uint8_t kv = val_lo | (val_hi << 4);
                out[${N} * 8 + i] = kv;
                ksum${N} += (int32_t)val_lo + (int32_t)val_hi - 16;
              }
            }
            w${N} += k;

          // Pad the remaining row(s)
          $for N in range(NR-1, NR):
            for (size_t i = 0; i < 8; ++i) {
              out[${N} * 8 + i] = 0;
            }
          out += ${NR} * 8;
        }

        $for N in range(NR-1):
          if (${N} < n) {
            packed_b[${N}] -= ksum${N} * izp${KSUM_SCALE};
          }
        out = (uint8_t*) ((uintptr_t) out + extra_bytes);
      }
      weights = (const uint8_t*)((intptr_t) weights + nc * kc);
    } while (--g != 0);
}
