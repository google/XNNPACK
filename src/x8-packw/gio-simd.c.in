$BATCH_TILES = tuple(int(bt) for bt in BATCH_TILES.split(","))
$SIMD_SIZE = BATCH_TILES[0]
#include <assert.h>
#include <stddef.h>
#include <stdint.h>
#include <string.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/packw.h"
$if PREFETCH:
  #include "src/xnnpack/prefetch.h"
#include "src/xnnpack/simd/s8-${ARCH}.h"


$for NR in BATCH_TILES:
  $SIMD_TILE = NR // SIMD_SIZE

  // Pack pre-transposed weights (GIO) for use by int8 gemm
  void xnn_x8_packw_gemm_gio_ukernel_x${NR}__${ARCH}_u${KBLOCK}${"_prfm" if PREFETCH else ""}(
    size_t g,                  // Batch size (outer loop). usually 1
    size_t nc,                 // Number of columns and typically large
    size_t kc,                 // Number of rows and typically small
    size_t nr,                 // Matches gemm and is a multiple of vector sizes
    size_t kr,                 // unused - must be 1
    size_t sr,                 // unused - must be 1
    size_t k_stride,           // Elements per row (typically same as nc)
    const int8_t* weights,     // Weights to pack. unaligned, unpadded
    const uint32_t* bias,      // Bias to pack. unaligned, unpadded, can be NULL
    const void* scale,         // unused
    int8_t* packed_weights,    // packed weights output buffer - aligned, padded
    size_t extra_bytes,        // number of extra bytes between weights. aligned
    const void* params)        // unused
  {
    assert(g != 0);
    assert(nc != 0);
    assert(kc != 0);
    assert(nr == ${NR});   // This kernel is for NR=${NR}
    assert(kr == 1);
    assert(sr == 1);
    assert(k_stride != 0);
    assert(weights != NULL);
    assert(packed_weights != NULL);

    const xnn_simd_s8_t vzero = xnn_set1_s8(0);
    (void) vzero;
    const uint32_t* b = bias;
    int8_t* packed_w = packed_weights;
    do {
      // NC main loop multiple of ${NR}
      const int8_t* w = weights;
      size_t n = nc;

      for (; n >= ${NR}; n -= ${NR}) {
        if XNN_LIKELY(b != NULL) {
          memcpy(packed_w, b, ${NR} * sizeof(uint32_t));
          packed_w += ${NR} * sizeof(uint32_t);
          b += ${NR};
        } else {
          memset(packed_w, 0, ${NR} * sizeof(uint32_t));
          packed_w += ${NR} * sizeof(uint32_t);
        }

        // KC main loop ${KBLOCK}x${NR}
        size_t k = kc;
        $if KBLOCK > 1:
          for (; k >= ${KBLOCK}; k -= ${KBLOCK}) {
            $for K in range(KBLOCK):
              $for N in range(SIMD_TILE):
                const xnn_simd_s8_t v${N}_${K} = xnn_loadu_s8(w + ${N*SIMD_SIZE} + ${K} * k_stride);
            $if PREFETCH:
              $for K in range(KBLOCK):
                $for N in range(SIMD_TILE):
                  xnn_prefetch_to_l1((const int8_t*) w + ${N*SIMD_SIZE+960});
            $for K in range(KBLOCK):
              $for N in range(SIMD_TILE):
                xnn_store_s8(packed_w + ${N*SIMD_SIZE+K*NR}, v${N}_${K});
            w += k_stride * ${KBLOCK};
            packed_w += ${NR*KBLOCK};
          }

        // KC remainder loop
        for (; k > 0; --k) {
          $for N in range(SIMD_TILE):
            const xnn_simd_s8_t v${N} = xnn_loadu_s8(w + ${N*SIMD_SIZE});
          $if PREFETCH:
            $for N in range(SIMD_TILE):
              xnn_prefetch_to_l1((const int8_t*) w + ${N*SIMD_SIZE+960});
          $for N in range(SIMD_TILE):
            xnn_store_s8(packed_w + ${N*SIMD_SIZE}, v${N});
          w += k_stride;
          packed_w += ${NR};
        }
        packed_w += extra_bytes;
        w = w - kc * k_stride + ${NR};  // Advance to next column of ${NR} int8_t
      }

      // NC remainder (1..${NR-1})
      if XNN_UNLIKELY(n != 0) {
        // Prepare count for valid elements (depends on n).
        $if SIMD_TILE > 1:
          $for N in range(SIMD_TILE):
            const size_t vcount${N} = (int) (n - ${N*SIMD_SIZE}) < 0 ? 0 : ((int) (n - ${N*SIMD_SIZE}) > ${SIMD_SIZE} ? ${SIMD_SIZE} : n - ${N*SIMD_SIZE});

        if XNN_LIKELY(b != NULL) {
          memcpy(packed_w, b, n * sizeof(uint32_t));
          memset(packed_w + n * sizeof(uint32_t), 0, (${NR} - n) * sizeof(uint32_t));
          packed_w += ${NR} * sizeof(uint32_t);
          b += n;
        } else {
          memset(packed_w, 0, ${NR} * sizeof(uint32_t));
          packed_w += ${NR} * sizeof(uint32_t);
        }

        // KC main loop
        for (size_t k = kc; k > 0; --k) {
          $for N in range(SIMD_TILE):
            $if SIMD_TILE == 1:
              const xnn_simd_s8_t v0 = xnn_load_tail_safe_s8(w, n);
            $else:
              const xnn_simd_s8_t v${N} = vcount${N} == ${SIMD_SIZE} ? xnn_loadu_s8(w + ${N*SIMD_SIZE}) : (vcount${N} == 0 ? vzero : xnn_load_tail_safe_s8(w + ${N*SIMD_SIZE}, vcount${N}));
          $for N in range(SIMD_TILE):
            xnn_store_s8(packed_w + ${N*SIMD_SIZE}, v${N});
          w += k_stride;
          packed_w += ${NR};
        }
        packed_w += extra_bytes;
      }
      weights += nc * kc;
    } while (--g != 0);
  }
