$assert DATATYPE in ["QS2", "QD8_QC2W"]
$assert IZP in [0, 128]
$assert KR == 4
$assert NR > 1
#include <assert.h>
#include <stddef.h>
#include <stdint.h>

#include <arm_neon.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/microparams.h"
#include "src/xnnpack/packw.h"

$WTYPE = "uint8_t"
$OUTTYPE = "uint8_t"
$PACKEDWTYPE = "void"
$BTYPE = "int32_t"
$SCALETYPE = "float"
$PARAMTYPE = {"QS2": "struct xnn_qs8_qc2w_packing_params", "QD8_QC2W": "struct xnn_qd8_qc2w_packing_params"}[DATATYPE]
$DATATYPE_SPEC = {"QS2": "qs8_to_qu8_qc2w" if IZP == 128 else "qs8_qc2w", "QD8_QC2W": "qd8_qc2w"}[DATATYPE]

// Sign extend 2-bit to 8-bit
inline static int8_t sign_extend_int2(uint8_t v) {
  return (int8_t)(v << 6) >> 6;
}

void xnn_${DATATYPE_SPEC}_packw_gemm_goi_ukernel_x${NR}c4__neondot(
  size_t g,
  size_t nc,
  size_t kc,
  size_t nr,
  size_t kr,
  size_t sr,
  const ${WTYPE}* weights,
  const ${BTYPE}* bias,
  const ${SCALETYPE}* scale,
  ${PACKEDWTYPE}* packed_weights,
  size_t extra_bytes,
  const ${PARAMTYPE}* params)
{
  assert(g != 0);
  assert(nc != 0);
  assert(kc != 0);
  assert(nr == ${NR});
  assert(kr == 4);
  assert(sr == 1);
  assert(weights != NULL);
  assert(packed_weights != NULL);
  assert(params != NULL);
  assert(kc % 4 == 0);

  const size_t mock_kc = kc >> 2; // kc in bytes (each byte has 4 2-bit weights)
  $if DATATYPE == "QS2":
    const uint32_t izp = (uint32_t) params->input_zero_point + ${IZP};
  $elif DATATYPE == "QD8_QC2W":
    const uint32_t izp = (uint32_t) params->input_zero_point;
    const float* kernel_zero_points = params->kernel_zero_point;

  ${OUTTYPE}* out = (${OUTTYPE}*) packed_weights;
  const ${BTYPE}* b = bias;

  do {
    const ${WTYPE}* w0 = weights;
    size_t n = nc;
    for (; n >= ${NR}; n -= ${NR}) {
      int32_t* packed_b = (int32_t*) out;
      if (b != NULL) {
        for (size_t i = 0; i < ${NR}; ++i) {
          packed_b[i] = b[i];
        }
        b += ${NR};
      } else {
        for (size_t i = 0; i < ${NR}; ++i) {
          packed_b[i] = 0;
        }
      }
      $if DATATYPE == "QD8_QC2W":
        float* packed_zp = (float*) (packed_b + ${NR});
        if (kernel_zero_points != NULL) {
          for (size_t i = 0; i < ${NR}; ++i) {
            packed_zp[i] = kernel_zero_points[i];
          }
          kernel_zero_points += ${NR};
        } else {
          for (size_t i = 0; i < ${NR}; ++i) {
            packed_zp[i] = 0.0f;
          }
        }
        out = (${OUTTYPE}*) (packed_zp + ${NR});
      $else:
        out = (${OUTTYPE}*) (packed_b + ${NR});

      $for N in range(1, NR):
        const ${WTYPE}* w${N} = w${N-1} + mock_kc;

      $for N in range(NR):
        int32_t ksum${N} = 0;

      // KC main loop multiple of 4 bytes (16 2-bit elements)
      size_t k = mock_kc;
      for (; k >= 4; k -= 4) {
        $for N in range(NR):
          for (size_t i = 0; i < 4; ++i) {
            const uint8_t b0 = w${N}[(i >> 2) + 0 * 1];
            const uint8_t b1 = w${N}[(i >> 2) + 1 * 1];
            const uint8_t b2 = w${N}[(i >> 2) + 2 * 1];
            const uint8_t b3 = w${N}[(i >> 2) + 3 * 1];
            const uint8_t shift = (i & 3) * 2;
            const uint8_t val0 = (b0 >> shift) & 3;
            const uint8_t val1 = (b1 >> shift) & 3;
            const uint8_t val2 = (b2 >> shift) & 3;
            const uint8_t val3 = (b3 >> shift) & 3;
            const uint8_t kv = val0 | (val1 << 2) | (val2 << 4) | (val3 << 6);
            $if IZP == 128 or DATATYPE == "QD8_QC2W":
              out[${N} * 4 + i] = kv ^ 0xAA;
            $else:
              out[${N} * 4 + i] = kv;
            ksum${N} += sign_extend_int2(val0) + sign_extend_int2(val1) + sign_extend_int2(val2) + sign_extend_int2(val3);
          }
          w${N} += 4;
        out += ${NR * 4};
      }

      // KC remainder of 1..3 bytes
      if (k != 0) {
        $for N in range(NR):
          uint8_t temp_w${N}[4];
          for (size_t i = 0; i < k; ++i) {
            temp_w${N}[i] = w${N}[i];
          }
          for (size_t i = k; i < 4; ++i) {
            temp_w${N}[i] = 0;
          }

        $for N in range(NR):
          for (size_t i = 0; i < 4; ++i) {
            const uint8_t b0 = temp_w${N}[(i >> 2) + 0 * 1];
            const uint8_t b1 = temp_w${N}[(i >> 2) + 1 * 1];
            const uint8_t b2 = temp_w${N}[(i >> 2) + 2 * 1];
            const uint8_t b3 = temp_w${N}[(i >> 2) + 3 * 1];
            const uint8_t shift = (i & 3) * 2;
            const uint8_t val0 = (b0 >> shift) & 3;
            const uint8_t val1 = (b1 >> shift) & 3;
            const uint8_t val2 = (b2 >> shift) & 3;
            const uint8_t val3 = (b3 >> shift) & 3;
            const uint8_t kv = val0 | (val1 << 2) | (val2 << 4) | (val3 << 6);
            $if IZP == 128 or DATATYPE == "QD8_QC2W":
              out[${N} * 4 + i] = kv ^ 0xAA;
            $else:
              out[${N} * 4 + i] = kv;
            ksum${N} += sign_extend_int2(val0) + sign_extend_int2(val1) + sign_extend_int2(val2) + sign_extend_int2(val3);
          }
          w${N} += k;
        out += ${NR * 4};
      }

      $for N in range(NR):
        packed_b[${N}] -= ksum${N} * izp;
      out = (${OUTTYPE}*) ((uintptr_t) out + extra_bytes);
      w0 = w${NR-1};
    }

    // NC remainder (1..${NR-1})
    if XNN_UNLIKELY(n != 0) {
      assert(n >= 1 && n <= ${NR-1});
      int32_t* packed_b = (int32_t*) out;
      if (b != NULL) {
        for (size_t i = 0; i < n; ++i) {
          packed_b[i] = b[i];
        }
        for (size_t i = n; i < ${NR}; ++i) {
          packed_b[i] = 0;
        }
        b += n;
      } else {
        for (size_t i = 0; i < ${NR}; ++i) {
          packed_b[i] = 0;
        }
      }
      $if DATATYPE == "QD8_QC2W":
        float* packed_zp = (float*) (packed_b + ${NR});
        if (kernel_zero_points != NULL) {
          for (size_t i = 0; i < n; ++i) {
            packed_zp[i] = kernel_zero_points[i];
          }
          for (size_t i = n; i < ${NR}; ++i) {
            packed_zp[i] = 0.0f;
          }
          kernel_zero_points += n;
        } else {
          for (size_t i = 0; i < ${NR}; ++i) {
            packed_zp[i] = 0.0f;
          }
        }
        out = (${OUTTYPE}*) (packed_zp + ${NR});
      $else:
        out = (${OUTTYPE}*) (packed_b + ${NR});

      $for N in range(1, NR):
        const ${WTYPE}* w${N} = w${N-1} + mock_kc;
        if XNN_UNPREDICTABLE(n <= ${N}) {
          w${N} = w${N-1};
        }

      $for N in range(NR):
        int32_t ksum${N} = 0;

      // KC main loop multiple of 4 bytes (16 2-bit elements)
      size_t k = mock_kc;
      for (; k >= 4; k -= 4) {
        $for N in range(NR):
          if XNN_LIKELY(${N} < n) {
            for (size_t i = 0; i < 4; ++i) {
              const uint8_t b0 = w${N}[(i >> 2) + 0 * 1];
              const uint8_t b1 = w${N}[(i >> 2) + 1 * 1];
              const uint8_t b2 = w${N}[(i >> 2) + 2 * 1];
              const uint8_t b3 = w${N}[(i >> 2) + 3 * 1];
              const uint8_t shift = (i & 3) * 2;
              const uint8_t val0 = (b0 >> shift) & 3;
              const uint8_t val1 = (b1 >> shift) & 3;
              const uint8_t val2 = (b2 >> shift) & 3;
              const uint8_t val3 = (b3 >> shift) & 3;
              const uint8_t kv = val0 | (val1 << 2) | (val2 << 4) | (val3 << 6);
              $if IZP == 128 or DATATYPE == "QD8_QC2W":
                out[${N} * 4 + i] = kv ^ 0xAA;
              $else:
                out[${N} * 4 + i] = kv;
              ksum${N} += sign_extend_int2(val0) + sign_extend_int2(val1) + sign_extend_int2(val2) + sign_extend_int2(val3);
            }
            w${N} += 4;
          } else {
            for (size_t i = 0; i < 4; ++i) {
              out[${N} * 4 + i] = 0;
            }
          }
        out += ${NR * 4};
      }

      // KC remainder of 1..3 bytes
      if (k != 0) {
        $for N in range(NR):
          if XNN_LIKELY(${N} < n) {
            uint8_t temp_w${N}[4];
            for (size_t i = 0; i < k; ++i) {
              temp_w${N}[i] = w${N}[i];
            }
            for (size_t i = k; i < 4; ++i) {
              temp_w${N}[i] = 0;
            }
            for (size_t i = 0; i < 4; ++i) {
              const uint8_t b0 = temp_w${N}[(i >> 2) + 0 * 1];
              const uint8_t b1 = temp_w${N}[(i >> 2) + 1 * 1];
              const uint8_t b2 = temp_w${N}[(i >> 2) + 2 * 1];
              const uint8_t b3 = temp_w${N}[(i >> 2) + 3 * 1];
              const uint8_t shift = (i & 3) * 2;
              const uint8_t val0 = (b0 >> shift) & 3;
              const uint8_t val1 = (b1 >> shift) & 3;
              const uint8_t val2 = (b2 >> shift) & 3;
              const uint8_t val3 = (b3 >> shift) & 3;
              const uint8_t kv = val0 | (val1 << 2) | (val2 << 4) | (val3 << 6);
              $if IZP == 128 or DATATYPE == "QD8_QC2W":
                out[${N} * 4 + i] = kv ^ 0xAA;
              $else:
                out[${N} * 4 + i] = kv;
              ksum${N} += sign_extend_int2(val0) + sign_extend_int2(val1) + sign_extend_int2(val2) + sign_extend_int2(val3);
            }
            w${N} += k;
          } else {
            for (size_t i = 0; i < 4; ++i) {
              out[${N} * 4 + i] = 0;
            }
          }
        out += ${NR * 4};
      }

      $for N in range(NR):
        if XNN_LIKELY(${N} < n) {
          packed_b[${N}] -= ksum${N} * izp;
        }
      out = (${OUTTYPE}*) ((uintptr_t) out + extra_bytes);
    }
    weights += nc * mock_kc;
  } while (--g != 0);
}
