$assert NR > 1
$assert NR % 8 == 0
$assert KR == 4
$assert DATATYPE in ["QS8", "X8"]
$assert TYPE in ["int8_t", "uint8_t"]
$assert IZP in [0, 128]

#include <arm_neon.h>
#include <assert.h>
#include <stddef.h>
#include <stdint.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/microparams.h"
#include "src/xnnpack/packw.h"
#include "src/xnnpack/unaligned.h"

XNN_INLINE static int32_t horizontal_add_s32(int32x4_t v) {
#if XNN_ARCH_ARM64
  return vaddvq_s32(v);
#else
  int32x2_t vacc_lo = vadd_s32(vget_low_s32(v), vget_high_s32(v));
  vacc_lo = vpadd_s32(vacc_lo, vacc_lo);
  return vget_lane_s32(vacc_lo, 0);
#endif
}


$BTYPE = {"QS8": "int32_t", "QS4": "int32_t", "X8": "uint32_t"}[DATATYPE]
$WTYPE = {"QS8": "int8_t", "QS4": "uint8_t", "X8": "int8_t"}[DATATYPE]
$PACKEDWTYPE = {"QS8": "int8_t", "QS4": "void", "X8": "int8_t"}[DATATYPE]
$PARAMTYPE = {"QS8": "void", "QS4": "struct xnn_qs8_qc4w_packing_params", "X8": "void"}[DATATYPE]
$SCALETYPE = "float" if DATATYPE == "QS4" else "void"
$DATATYPE_SPEC = ("qs8_to_qu8_qc4w" if DATATYPE == "QS4" else "qs8_to_qu8") if IZP == 128 else {"QS8": "qs8", "QS4": "qs8_qc4w", "X8": "x8"}[DATATYPE]
$ISA = "neon" if DATATYPE == "X8" else "neondot"

void xnn_${DATATYPE_SPEC}_packw_gemm_goi_ukernel_x${NR}c4__${ISA}(
  size_t g,
  size_t nc,
  size_t kc,
  size_t nr,
  size_t kr,
  size_t sr,
  const ${TYPE}* weights,
  const ${BTYPE}* bias,
  const ${SCALETYPE}* scale,
  ${PACKEDWTYPE}* packed_weights,
  size_t extra_bytes,
  const ${PARAMTYPE}* params)
{
  assert(g != 0);
  assert(nc != 0);
  assert(kc != 0);
  assert(nr == ${NR});
  assert(kr == 4);
  assert(sr == 1);
  assert(weights != NULL);
  assert(packed_weights != NULL);

  $if DATATYPE == "QS4":
    assert(params != NULL);
    const int8_t kzp = (int8_t) params->kernel_zero_point;
    assert(kzp == 0 || kzp == 8);
    const uint8x8_t vkzp = vdup_n_u8(kzp * 0x11);
    const int32_t izp = (int32_t) params->input_zero_point;
    const int8x16_t vones = vdupq_n_s8(1);
    const size_t mock_kc = kc >> 1;
  $elif DATATYPE == "QS8":
    const int32_t izp = (int32_t) (params ? (((const struct xnn_qs8_packw_params*) params)->input_zero_point): 0);
    const int8x16_t vones = vdupq_n_s8(1);
    const size_t mock_kc = kc;
  $else:
    const size_t mock_kc = kc;

  ${WTYPE}* out = (${WTYPE}*) packed_weights;
  const ${BTYPE}* b = (const ${BTYPE}*) bias;

  do {
    const ${TYPE}* w0 = weights;
    size_t n = nc;
    for (; n >= ${NR}; n -= ${NR}) {
      $if DATATYPE in ["QS8", "QS4"]:
        int32_t* packed_b = (int32_t*) out;
      if (b != NULL) {
        for (size_t i = 0; i < ${NR}; ++i) {
          $if DATATYPE == "QS4":
            ((${BTYPE}*) out)[i] = b[i] * 16;
          $else:
            ((${BTYPE}*) out)[i] = b[i];
        }
        b += ${NR};
      } else {
        for (size_t i = 0; i < ${NR}; ++i) {
          ((${BTYPE}*) out)[i] = 0;
        }
      }
      out = (${WTYPE}*) ((uintptr_t) out + ${NR} * sizeof(${BTYPE}));

      $for N in range(1, NR):
        const ${TYPE}* w${N} = w${N-1} + mock_kc;

      $if DATATYPE in ["QS8", "QS4"]:
        $for N in range(NR):
          int32x4_t vacc${N} = vdupq_n_s32(0);

      size_t k = mock_kc;
      for (; k >= 16; k -= 16) {
        $if DATATYPE == "QS4":
          $for N in range(NR):
            uint8x8_t b${N} = vld1_u8(w${N}); w${N} += 8;
            if (kzp != 0) {
              b${N} = veor_u8(b${N}, vkzp);
            }
            const int8x16_t unp${N} = vcombine_s8(vreinterpret_s8_u8(vand_u8(b${N}, vdup_n_u8(0x0F))), vreinterpret_s8_u8(vshr_n_u8(b${N}, 4)));
            vacc${N} = vdotq_s32(vacc${N}, unp${N}, vones);
        $elif DATATYPE == "QS8":
          $for N in range(NR):
            const int8x16_t v${N} = vld1q_s8(w${N}); w${N} += 16;
            vacc${N} = vdotq_s32(vacc${N}, v${N}, vones);
        $else:
          $for N in range(NR):
            const int8x16_t v${N} = vld1q_s8(w${N}); w${N} += 16;

        $if DATATYPE in ["QS8", "X8"]:
          $for N_BLOCK in range(0, NR, 4):
            const int32x4_t x0_${N_BLOCK} = vreinterpretq_s32_s8(v${N_BLOCK+0});
            const int32x4_t x1_${N_BLOCK} = vreinterpretq_s32_s8(v${N_BLOCK+1});
            const int32x4_t x2_${N_BLOCK} = vreinterpretq_s32_s8(v${N_BLOCK+2});
            const int32x4_t x3_${N_BLOCK} = vreinterpretq_s32_s8(v${N_BLOCK+3});

            const int32x4x2_t t01_${N_BLOCK} = vzipq_s32(x0_${N_BLOCK}, x2_${N_BLOCK});
            const int32x4x2_t t23_${N_BLOCK} = vzipq_s32(x1_${N_BLOCK}, x3_${N_BLOCK});
            const int32x4_t t0_${N_BLOCK} = t01_${N_BLOCK}.val[0];
            const int32x4_t t1_${N_BLOCK} = t01_${N_BLOCK}.val[1];
            const int32x4_t t2_${N_BLOCK} = t23_${N_BLOCK}.val[0];
            const int32x4_t t3_${N_BLOCK} = t23_${N_BLOCK}.val[1];

            const int32x4x2_t s01_${N_BLOCK} = vzipq_s32(t0_${N_BLOCK}, t2_${N_BLOCK});
            const int32x4x2_t s23_${N_BLOCK} = vzipq_s32(t1_${N_BLOCK}, t3_${N_BLOCK});
            const int32x4_t s0_${N_BLOCK} = s01_${N_BLOCK}.val[0];
            const int32x4_t s1_${N_BLOCK} = s01_${N_BLOCK}.val[1];
            const int32x4_t s2_${N_BLOCK} = s23_${N_BLOCK}.val[0];
            const int32x4_t s3_${N_BLOCK} = s23_${N_BLOCK}.val[1];

          $for I in range(4):
            $for N_BLOCK in range(0, NR, 4):
              vst1q_s32((int32_t*)out + ${I * NR + N_BLOCK}, s${I}_${N_BLOCK});
          out += ${4 * NR * 4};
        $else:
          $for N_BLOCK in range(0, NR, 4):
            const uint16x4_t y0_${N_BLOCK} = vreinterpret_u16_u8(b${N_BLOCK+0});
            const uint16x4_t y1_${N_BLOCK} = vreinterpret_u16_u8(b${N_BLOCK+1});
            const uint16x4_t y2_${N_BLOCK} = vreinterpret_u16_u8(b${N_BLOCK+2});
            const uint16x4_t y3_${N_BLOCK} = vreinterpret_u16_u8(b${N_BLOCK+3});

            const uint16x4x2_t u01_${N_BLOCK} = vzip_u16(y0_${N_BLOCK}, y2_${N_BLOCK});
            const uint16x4x2_t u23_${N_BLOCK} = vzip_u16(y1_${N_BLOCK}, y3_${N_BLOCK});
            const uint16x4_t u0_${N_BLOCK} = u01_${N_BLOCK}.val[0];
            const uint16x4_t u1_${N_BLOCK} = u01_${N_BLOCK}.val[1];
            const uint16x4_t u2_${N_BLOCK} = u23_${N_BLOCK}.val[0];
            const uint16x4_t u3_${N_BLOCK} = u23_${N_BLOCK}.val[1];

            const uint16x4x2_t s01_${N_BLOCK} = vzip_u16(u0_${N_BLOCK}, u2_${N_BLOCK});
            const uint16x4x2_t s23_${N_BLOCK} = vzip_u16(u1_${N_BLOCK}, u3_${N_BLOCK});
            const uint16x4_t s0_${N_BLOCK} = s01_${N_BLOCK}.val[0];
            const uint16x4_t s1_${N_BLOCK} = s01_${N_BLOCK}.val[1];
            const uint16x4_t s2_${N_BLOCK} = s23_${N_BLOCK}.val[0];
            const uint16x4_t s3_${N_BLOCK} = s23_${N_BLOCK}.val[1];

          $for I in range(4):
            $for N_BLOCK in range(0, NR, 8):
              vst1q_u16((uint16_t*)out + ${I * NR + N_BLOCK}, vcombine_u16(s${I}_${N_BLOCK}, s${I}_${N_BLOCK+4}));
          out += ${4 * NR * 2};
      }

      $if DATATYPE in ["QS8", "QS4"]:
        $for N in range(NR):
          int32_t rem_ksum${N} = 0;

      $if DATATYPE == "QS4":
        const size_t rem_step = 2;
      $else:
        const size_t rem_step = 4;
      for (; k >= rem_step; k -= rem_step) {
        $for N in range(NR):
          $if DATATYPE == "QS4":
            uint16_t v${N} = unaligned_load_u16(w${N}); w${N} += 2;
            if (kzp != 0) {
              v${N} ^= (kzp * 0x1111);
            }
            rem_ksum${N} += (v${N} & 0xF) + ((v${N} >> 4) & 0xF) + ((v${N} >> 8) & 0xF) + (v${N} >> 12);
            ((uint16_t*) out)[${N}] = v${N};
          $else:
            const uint32_t v${N} = unaligned_load_u32(w${N}); w${N} += 4;
            $if DATATYPE == "QS8":
              const int8_t* p${N} = (const int8_t*)&v${N};
              rem_ksum${N} += p${N}[0] + p${N}[1] + p${N}[2] + p${N}[3];
            ((uint32_t*) out)[${N}] = v${N};
        out += ${NR} * rem_step;
      }

      if (k != 0) {
        $for N in range(NR):
          $if DATATYPE == "QS4":
            assert(k == 1);
            uint16_t v${N} = w${N}[0]; w${N} += 1;
            if (kzp != 0) {
              v${N} ^= (kzp * 0x1111);
            }
            rem_ksum${N} += (v${N} & 0xF) + ((v${N} >> 4) & 0xF);
            ((uint16_t*) out)[${N}] = v${N};
          $else:
            assert(k >= 1 && k <= 3);
            uint32_t v${N} = 0;
            for (size_t i = 0; i < k; ++i) {
              v${N} |= ((uint32_t) ((uint8_t) w${N}[i])) << (i * 8);
            }
            w${N} += k;
            $if DATATYPE == "QS8":
              const int8_t* p${N} = (const int8_t*) &v${N};
              rem_ksum${N} += p${N}[0] + p${N}[1] + p${N}[2] + p${N}[3];
            ((uint32_t*) out)[${N}] = v${N};
        out += ${NR} * rem_step;
      }

      $if DATATYPE in ["QS8", "QS4"]:
        $for N in range(NR):
          const int32_t ksum${N} = horizontal_add_s32(vacc${N}) + rem_ksum${N};
          $if DATATYPE == "QS4":
            packed_b[${N}] -= ksum${N} * izp * 16;
          $else:
            packed_b[${N}] -= ksum${N} * izp;

      out = (${WTYPE}*) ((uintptr_t) out + extra_bytes);
      w0 = w${NR-1};
    }

    if XNN_UNLIKELY(n != 0) {
      assert(n >= 1 && n <= ${NR-1});
      $for N in range(1, NR):
        const ${TYPE}* w${N} = w${N-1} + mock_kc;
        $if N % 2 == 0:
          if XNN_UNPREDICTABLE(n <= ${N}) {
            w${N} = w${N-1};
          }
        $else:
          if XNN_UNPREDICTABLE(n < ${N+1}) {
            w${N} = w${N-1};
          }

      $if DATATYPE in ["QS8", "QS4"]:
        int32_t* packed_b = (int32_t*) out;
      if (b != NULL) {
        for (size_t i = 0; i < n; ++i) {
          $if DATATYPE == "QS4":
            ((${BTYPE}*) out)[i] = b[i] * 16;
          $else:
            ((${BTYPE}*) out)[i] = b[i];
        }
        b += n;
      } else {
        for (size_t i = 0; i < n; ++i) {
          ((${BTYPE}*) out)[i] = 0;
        }
      }
      out = (${WTYPE}*) ((uintptr_t) out + ${NR} * sizeof(${BTYPE}));

      $if DATATYPE in ["QS8", "QS4"]:
        $for N in range(NR):
          int32x4_t vacc${N} = vdupq_n_s32(0);

      size_t k = mock_kc;
      for (; k >= 16; k -= 16) {
        $if DATATYPE == "QS4":
          $for N in range(NR):
            uint8x8_t b${N} = vld1_u8(w${N}); w${N} += 8;
            if (kzp != 0) {
              b${N} = veor_u8(b${N}, vkzp);
            }
            const int8x16_t unp${N} = vcombine_s8(vreinterpret_s8_u8(vand_u8(b${N}, vdup_n_u8(0x0F))), vreinterpret_s8_u8(vshr_n_u8(b${N}, 4)));
            vacc${N} = vdotq_s32(vacc${N}, unp${N}, vones);
        $elif DATATYPE == "QS8":
          $for N in range(NR):
            const int8x16_t v${N} = vld1q_s8(w${N}); w${N} += 16;
            vacc${N} = vdotq_s32(vacc${N}, v${N}, vones);
        $else:
          $for N in range(NR):
            const int8x16_t v${N} = vld1q_s8(w${N}); w${N} += 16;

        $if DATATYPE in ["QS8", "X8"]:
          $for N_BLOCK in range(0, NR, 4):
            const int32x4_t x0_${N_BLOCK} = vreinterpretq_s32_s8(v${N_BLOCK+0});
            const int32x4_t x1_${N_BLOCK} = vreinterpretq_s32_s8(v${N_BLOCK+1});
            const int32x4_t x2_${N_BLOCK} = vreinterpretq_s32_s8(v${N_BLOCK+2});
            const int32x4_t x3_${N_BLOCK} = vreinterpretq_s32_s8(v${N_BLOCK+3});

            const int32x4x2_t t01_${N_BLOCK} = vzipq_s32(x0_${N_BLOCK}, x2_${N_BLOCK});
            const int32x4x2_t t23_${N_BLOCK} = vzipq_s32(x1_${N_BLOCK}, x3_${N_BLOCK});
            const int32x4_t t0_${N_BLOCK} = t01_${N_BLOCK}.val[0];
            const int32x4_t t1_${N_BLOCK} = t01_${N_BLOCK}.val[1];
            const int32x4_t t2_${N_BLOCK} = t23_${N_BLOCK}.val[0];
            const int32x4_t t3_${N_BLOCK} = t23_${N_BLOCK}.val[1];

            const int32x4x2_t s01_${N_BLOCK} = vzipq_s32(t0_${N_BLOCK}, t2_${N_BLOCK});
            const int32x4x2_t s23_${N_BLOCK} = vzipq_s32(t1_${N_BLOCK}, t3_${N_BLOCK});
            const int32x4_t s0_${N_BLOCK} = s01_${N_BLOCK}.val[0];
            const int32x4_t s1_${N_BLOCK} = s01_${N_BLOCK}.val[1];
            const int32x4_t s2_${N_BLOCK} = s23_${N_BLOCK}.val[0];
            const int32x4_t s3_${N_BLOCK} = s23_${N_BLOCK}.val[1];

          $for I in range(4):
            $for N_BLOCK in range(0, NR, 4):
              vst1q_s32((int32_t*)out + ${I * NR + N_BLOCK}, s${I}_${N_BLOCK});
          out += ${4 * NR * 4};
        $else:
          $for N_BLOCK in range(0, NR, 4):
            const uint16x4_t y0_${N_BLOCK} = vreinterpret_u16_u8(b${N_BLOCK+0});
            const uint16x4_t y1_${N_BLOCK} = vreinterpret_u16_u8(b${N_BLOCK+1});
            const uint16x4_t y2_${N_BLOCK} = vreinterpret_u16_u8(b${N_BLOCK+2});
            const uint16x4_t y3_${N_BLOCK} = vreinterpret_u16_u8(b${N_BLOCK+3});

            const uint16x4x2_t u01_${N_BLOCK} = vzip_u16(y0_${N_BLOCK}, y2_${N_BLOCK});
            const uint16x4x2_t u23_${N_BLOCK} = vzip_u16(y1_${N_BLOCK}, y3_${N_BLOCK});
            const uint16x4_t u0_${N_BLOCK} = u01_${N_BLOCK}.val[0];
            const uint16x4_t u1_${N_BLOCK} = u01_${N_BLOCK}.val[1];
            const uint16x4_t u2_${N_BLOCK} = u23_${N_BLOCK}.val[0];
            const uint16x4_t u3_${N_BLOCK} = u23_${N_BLOCK}.val[1];

            const uint16x4x2_t s01_${N_BLOCK} = vzip_u16(u0_${N_BLOCK}, u2_${N_BLOCK});
            const uint16x4x2_t s23_${N_BLOCK} = vzip_u16(u1_${N_BLOCK}, u3_${N_BLOCK});
            const uint16x4_t s0_${N_BLOCK} = s01_${N_BLOCK}.val[0];
            const uint16x4_t s1_${N_BLOCK} = s01_${N_BLOCK}.val[1];
            const uint16x4_t s2_${N_BLOCK} = s23_${N_BLOCK}.val[0];
            const uint16x4_t s3_${N_BLOCK} = s23_${N_BLOCK}.val[1];

          $for I in range(4):
            $for N_BLOCK in range(0, NR, 8):
              vst1q_u16((uint16_t*)out + ${I * NR + N_BLOCK}, vcombine_u16(s${I}_${N_BLOCK}, s${I}_${N_BLOCK+4}));
          out += ${4 * NR * 2};
      }

      $if DATATYPE in ["QS8", "QS4"]:
        $for N in range(NR):
          int32_t rem_ksum${N} = 0;

      $if DATATYPE == "QS4":
        const size_t rem_step = 2;
      $else:
        const size_t rem_step = 4;
      for (; k >= rem_step; k -= rem_step) {
        $for N in range(NR):
          $if DATATYPE == "QS4":
            uint16_t v${N} = unaligned_load_u16(w${N}); w${N} += 2;
            if (kzp != 0) {
              v${N} ^= (kzp * 0x1111);
            }
            rem_ksum${N} += (v${N} & 0xF) + ((v${N} >> 4) & 0xF) + ((v${N} >> 8) & 0xF) + (v${N} >> 12);
            ((uint16_t*) out)[${N}] = v${N};
          $else:
            const uint32_t v${N} = unaligned_load_u32(w${N}); w${N} += 4;
            $if DATATYPE == "QS8":
              const int8_t* p${N} = (const int8_t*)&v${N};
              rem_ksum${N} += p${N}[0] + p${N}[1] + p${N}[2] + p${N}[3];
            ((uint32_t*) out)[${N}] = v${N};
        out += ${NR} * rem_step;
      }

      if (k != 0) {
        $for N in range(NR):
          $if DATATYPE == "QS4":
            assert(k == 1);
            uint16_t v${N} = w${N}[0]; w${N} += 1;
            if (kzp != 0) {
              v${N} ^= (kzp * 0x1111);
            }
            rem_ksum${N} += (v${N} & 0xF) + ((v${N} >> 4) & 0xF);
            ((uint16_t*) out)[${N}] = v${N};
          $else:
            assert(k >= 1 && k <= 3);
            uint32_t v${N} = 0;
            for (size_t i = 0; i < k; ++i) {
              v${N} |= ((uint32_t) ((uint8_t) w${N}[i])) << (i * 8);
            }
            w${N} += k;
            $if DATATYPE == "QS8":
              const int8_t* p${N} = (const int8_t*) &v${N};
              rem_ksum${N} += p${N}[0] + p${N}[1] + p${N}[2] + p${N}[3];
            ((uint32_t*) out)[${N}] = v${N};
        out += ${NR} * rem_step;
      }

      $if DATATYPE in ["QS8", "QS4"]:
        $for N in range(NR):
          if (${N} < n) {
            const int32_t ksum${N} = horizontal_add_s32(vacc${N}) + rem_ksum${N};
            $if DATATYPE == "QS4":
              packed_b[${N}] -= ksum${N} * izp * 16;
            $else:
              packed_b[${N}] -= ksum${N} * izp;
          }

      out = (${WTYPE}*) ((uintptr_t) out + extra_bytes);
    }

    $if DATATYPE == "QS4":
      weights = (const ${TYPE}*)((intptr_t) weights + nc * (kc >> 1));
    $else:
      weights = (const ${TYPE}*)((intptr_t) weights + nc * kc);
  } while (--g != 0);
}
