$assert LMUL in [1, 2, 4]

#include <assert.h>

#include <riscv_vector.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/reduce.h"


void xnn_f16_f32acc_rdsum_ukernel_${ACCUMULATORS}p${ACCUMULATORS}x__rvvfp16arith_u${LMUL}v(
    size_t channels,
    size_t k1,
    size_t k2,
    size_t k3,
    const xnn_float16* input,
    size_t input_stride1,
    size_t input_stride2,
    size_t input_stride3,
    const xnn_float16* zero,
    float* output,
    const struct xnn_f16_f32acc_scale_params* restrict params)
{
  assert(k1 != 0);
  assert(channels != 0);
  assert(input != NULL);
  assert(output != NULL);

  const float scale = params->scalar.scale;
  float* original_output = output;
  size_t original_channels = channels;

  size_t input_increment = ${ACCUMULATORS} * input_stride1;
  for (size_t k = 0; k < k3; ++k) {
    for (size_t j = 0; j < k2; ++j) {
      const xnn_float16* input_row = (const xnn_float16*)((uintptr_t)input + j * input_stride2 + k * input_stride3);
      output = original_output;
      channels = original_channels;

      for (; channels > 0; ) {
        size_t n = __riscv_vsetvl_e16m${LMUL}(channels); channels -= n;
        const xnn_float16* i0 = input_row;
        $for i in range(1, ACCUMULATORS):
          const xnn_float16* i${i} = (const xnn_float16*) ((uintptr_t) i${i - 1} + input_stride1);
        vfloat32m${LMUL*2}_t acc_f32v = __riscv_vfmv_v_f_f32m${LMUL*2}(0.f, n);

        for (int r = k1; r > 0; r -= ${ACCUMULATORS}) {
          $for N in range(1, ACCUMULATORS, 2):
            if XNN_UNPREDICTABLE(r < ${N+1}) {
              i${N} = zero;
            }
            if XNN_UNPREDICTABLE(r <= ${N+1}) {
              i${N+1} = zero;
            }

          $for N in range(0, ACCUMULATORS):
            vfloat16m${LMUL}_t in${N}_f16v = __riscv_vle16_v_f16m${LMUL}(i${N}, n);
            acc_f32v = __riscv_vfwadd_wv(acc_f32v, in${N}_f16v, n);

          $for N in range(0, ACCUMULATORS):
            i${N} = (const xnn_float16*) ((uintptr_t) i${N} + input_increment);
        }
        acc_f32v = __riscv_vfmul(acc_f32v, scale, n);
        vfloat32m${LMUL*2}_t out_f32v = __riscv_vle32_v_f32m${LMUL*2}(output, n);
        out_f32v = __riscv_vfadd(out_f32v, acc_f32v, n);
        __riscv_vse32(output, out_f32v, n); output += n;

        input_row = (const xnn_float16*) ((uintptr_t) input_row + n * sizeof(xnn_float16));
      }
    }
  }
}
