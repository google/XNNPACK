$assert LMUL in [1, 2, 4]

#include <assert.h>

#include <riscv_vector.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/reduce.h"

void xnn_f16_f32acc_rsum_ukernel__rvvfp16arith_u${LMUL}v(
    size_t batch,
    const xnn_float16* input,
    float* output,
    const struct xnn_f16_f32acc_scale_params* restrict params)
{
  assert(batch != 0);
  assert(batch % sizeof(xnn_float16) == 0);
  assert(input != NULL);
  assert(output != NULL);

  batch >>= XNN_LOG2_SIZEOF_FLOAT16;

  size_t vlmax = __riscv_vsetvl_e32m${LMUL*2}(batch);
  vfloat32m${LMUL*2}_t vsum = __riscv_vfmv_v_f_f32m${LMUL*2}(0.f, vlmax);
 
  do {
    size_t vl = __riscv_vsetvl_e16m${LMUL}(batch); batch -= vl;

    vfloat16m${LMUL}_t vinput = __riscv_vle16_v_f16m${LMUL}(input, vl); input += vl;

    vsum = __riscv_vfwadd_wv(vsum, vinput, vl);

  } while (batch > 0);

  vfloat32m1_t vzero = __riscv_vfmv_v_f_f32m1(0.f, __riscv_vsetvlmax_e32m1());
  vfloat32m1_t vred = __riscv_vfredosum(vsum, vzero, vlmax);
  const float vscale = params->scalar.scale;
  *output += __riscv_vfmv_f_s_f32m1_f32(vred) * vscale;
}
