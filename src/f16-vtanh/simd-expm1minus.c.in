$assert (P, H) in [(3, 2)]
$assert not PS or (P, H) == (4, 3)
$assert DIV in ["DIV", "RECPEADJ", "NR1RECPS", "NR1FMA"]
$BATCH_TILES = tuple(int(bt) for bt in BATCH_TILES.split(","))
$SIMD_SIZE = BATCH_TILES[0]
$ABCX = "0123456789ABCXDEFGHIJKLMNOPQRSTUVWXYZ"
#include <assert.h>
#include <stddef.h>
#include <stdint.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/math.h"
#include "src/xnnpack/microparams.h"
#include "src/xnnpack/simd/f16-${ARCH}.h"
#include "src/xnnpack/vunary.h"

$POLY_SUFFIX = "p%dh%d%s" % (P, H, "ps" if PS else "ts")
$DIV_SUFFIX = DIV.lower()
$for BATCH_TILE in BATCH_TILES:
  $ABCX = "0123456789ABCXDEFGHIJKLMNOPQRSTUVWXYZ"
  $assert BATCH_TILE % SIMD_SIZE == 0
  $assert BATCH_TILE >= SIMD_SIZE
  $SIMD_TILE = BATCH_TILE // SIMD_SIZE

  void xnn_f16_vtanh_ukernel__${ARCH}_expm1minus_rr1_${POLY_SUFFIX}_${DIV_SUFFIX}_u${BATCH_TILE}(
      size_t batch,
      const xnn_float16* input,
      xnn_float16* output,
      const struct xnn_f16_default_params* restrict params) XNN_OOB_READS
  {
    assert(batch != 0);
    assert(batch % sizeof(xnn_float16) == 0);
    assert(input != NULL);
    assert(output != NULL);
    assert(xnn_simd_size_f16 == ${SIMD_SIZE});

    XNN_SIMD_CONST_F16_FROM_FLOAT(vsat_cutoff, 0x1.208p+2f);
    XNN_SIMD_CONST_F16_FROM_FLOAT(vmagic_bias, 0x1.83Cp+9f); // 0x620F
    XNN_SIMD_CONST_F16_FROM_FLOAT(vminus_log2e, -0x1.714p+0f); // 0xBDC5
    XNN_SIMD_CONST_F16_FROM_FLOAT(vln2, 0x1.630p-1f); // 0x398C
    XNN_SIMD_CONST_F16_FROM_FLOAT(vc3, -0x1.56Cp+0f); // 0xBD5B
    XNN_SIMD_CONST_F16_FROM_FLOAT(vc2, 0x1.020p+1f); // 0x4008
    XNN_SIMD_CONST_F16_FROM_FLOAT(vtwo, 2.0f);
    XNN_SIMD_CONST_F16_FROM_FLOAT(vminus_one, -1.0f);
    XNN_SIMD_CONST_F16_FROM_FLOAT(vsign_mask, -0.0f);

    const xnn_float16* i = input;
    xnn_float16* o = output;
    $for SIMD_TILE_LEVEL in (SIMD_TILE, 1) if SIMD_TILE > 1 else (1,):
      $if SIMD_TILE_LEVEL == 1:
        $ABCX =  ["" for a in ABCX]
      for (; batch >= ${SIMD_TILE_LEVEL} * xnn_simd_bytes_f16; batch -= ${SIMD_TILE_LEVEL} * xnn_simd_bytes_f16) {
        $for N in range(SIMD_TILE_LEVEL):
          const xnn_simd_f16_t vx${ABCX[N]} = xnn_loadu_f16(i); i += ${SIMD_SIZE};

        $for N in range(SIMD_TILE_LEVEL):
          xnn_simd_f16_t vz${ABCX[N]} = xnn_abs_f16(vx${ABCX[N]});

        $for N in range(SIMD_TILE_LEVEL):
          vz${ABCX[N]} = xnn_min_f16(vz${ABCX[N]}, vsat_cutoff);

        $for N in range(SIMD_TILE_LEVEL):
          xnn_simd_f16_t vn${ABCX[N]} = xnn_fmadd_f16(vz${ABCX[N]}, vminus_log2e, vmagic_bias);

        $for N in range(SIMD_TILE_LEVEL):
          const xnn_simd_f16_t vs${ABCX[N]} = xnn_sll_f16(vn${ABCX[N]}, 10);
          vn${ABCX[N]} = xnn_sub_f16(vn${ABCX[N]}, vmagic_bias);
        $for N in range(SIMD_TILE_LEVEL):
          const xnn_simd_f16_t vt${ABCX[N]} = xnn_fmadd_f16(vn${ABCX[N]}, vln2, vz${ABCX[N]});
        $for N in range(SIMD_TILE_LEVEL):
          xnn_simd_f16_t vp${ABCX[N]} = xnn_fmadd_f16(vt${ABCX[N]}, vc${P}, vc${P-1});
        $for idx in reversed(range(2, P - 1)):
          $for N in range(SIMD_TILE_LEVEL):
            vp${ABCX[N]} = xnn_fmadd_f16(vt${ABCX[N]}, vp${ABCX[N]}, vc${idx});
        $for N in range(SIMD_TILE_LEVEL):
          vp${ABCX[N]} = xnn_fnmadd_f16(vp${ABCX[N]}, vt${ABCX[N]}, vtwo);

        $for N in range(SIMD_TILE_LEVEL):
          const xnn_simd_f16_t vts${ABCX[N]} = xnn_mul_f16(vt${ABCX[N]}, vs${ABCX[N]});
          const xnn_simd_f16_t vsmo${ABCX[N]} = xnn_add_f16(vs${ABCX[N]}, vminus_one);
        $for N in range(SIMD_TILE_LEVEL):
          const xnn_simd_f16_t vemo${ABCX[N]} = xnn_fnmadd_f16(vp${ABCX[N]}, vts${ABCX[N]}, vsmo${ABCX[N]});
        $for N in range(SIMD_TILE_LEVEL):
          const xnn_simd_f16_t vepo${ABCX[N]} = xnn_add_f16(vemo${ABCX[N]}, vtwo);

        $if DIV == "DIV":
          $for N in range(SIMD_TILE_LEVEL):
            xnn_simd_f16_t vy${ABCX[N]} = xnn_div_f16(vemo${ABCX[N]}, vepo${ABCX[N]});
        $else:
          $for N in range(SIMD_TILE_LEVEL):
            xnn_simd_f16_t vrepo${ABCX[N]} = xnn_rcp_f16(vepo${ABCX[N]});
          $if DIV.startswith("NR1RECPS"):
            $for N in range(SIMD_TILE_LEVEL):
              const xnn_simd_f16_t verepo${ABCX[N]} = xnn_fnmadd_f16(vrepo${ABCX[N]}, vepo${ABCX[N]}, vtwo);
            $for N in range(SIMD_TILE_LEVEL):
              vrepo${ABCX[N]} = xnn_mul_f16(vrepo${ABCX[N]}, verepo${ABCX[N]});
          $elif DIV.startswith("NR1FMA"):
            $for N in range(SIMD_TILE_LEVEL):
              const xnn_simd_f16_t verepo${ABCX[N]} = xnn_fmadd_f16(vrepo${ABCX[N]}, vepo${ABCX[N]}, vminus_one);
            $for N in range(SIMD_TILE_LEVEL):
              vrepo${ABCX[N]} = xnn_fnmadd_f16(vrepo${ABCX[N]}, verepo${ABCX[N]}, vrepo${ABCX[N]});

          $for N in range(SIMD_TILE_LEVEL):
            xnn_simd_f16_t vy${ABCX[N]} = xnn_mul_f16(vemo${ABCX[N]}, vrepo${ABCX[N]});

          $if DIV.endswith("ADJ"):
            $for N in range(SIMD_TILE_LEVEL):
              const xnn_simd_f16_t vey${ABCX[N]} = xnn_fnmadd_f16(vy${ABCX[N]}, vepo${ABCX[N]}, vemo${ABCX[N]});
            $for N in range(SIMD_TILE_LEVEL):
              vy${ABCX[N]} = xnn_fmadd_f16(vey${ABCX[N]}, vrepo${ABCX[N]}, vy${ABCX[N]});

        $for N in range(SIMD_TILE_LEVEL):
          vy${ABCX[N]} = xnn_xor_f16(vy${ABCX[N]}, xnn_and_f16(xnn_xor_f16(vx${ABCX[N]}, vy${ABCX[N]}), vsign_mask));

        $for N in range(SIMD_TILE_LEVEL):
          xnn_storeu_f16(o, vy${ABCX[N]}); o += ${SIMD_SIZE};
      }

    $if SIMD_SIZE > 1:
      if XNN_UNLIKELY(batch != 0) {
        const xnn_simd_f16_t vx = xnn_load_tail_f16(i, batch >> XNN_LOG2_SIZEOF_FLOAT16);
        xnn_simd_f16_t vz = xnn_abs_f16(vx);
        vz = xnn_min_f16(vz, vsat_cutoff);

        xnn_simd_f16_t vn = xnn_fmadd_f16(vz, vminus_log2e, vmagic_bias);
        const xnn_simd_f16_t vs = xnn_sll_f16(vn, 10);
        vn = xnn_sub_f16(vn, vmagic_bias);
        const xnn_simd_f16_t vt = xnn_fmadd_f16(vn, vln2, vz);
        xnn_simd_f16_t vp = xnn_fmadd_f16(vt, vc${P}, vc${P-1});
        $for idx in reversed(range(2, P - 1)):
          vp = xnn_fmadd_f16(vt, vp, vc${idx});
        vp = xnn_fnmadd_f16(vp, vt, vtwo);

        const xnn_simd_f16_t vts = xnn_mul_f16(vt, vs);
        const xnn_simd_f16_t vsmo = xnn_add_f16(vs, vminus_one);
        const xnn_simd_f16_t vemo = xnn_fnmadd_f16(vp, vts, vsmo);
        const xnn_simd_f16_t vepo = xnn_add_f16(vemo, vtwo);

        $if DIV == "DIV":
          xnn_simd_f16_t vy = xnn_div_f16(vemo, vepo);
        $else:
          xnn_simd_f16_t vrepo = xnn_rcp_f16(vepo);
          $if DIV.startswith("NR1RECPS"):
            const xnn_simd_f16_t verepo = xnn_fnmadd_f16(vrepo, vepo, vtwo);
            vrepo = xnn_mul_f16(vrepo, verepo);
          $elif DIV.startswith("NR1FMA"):
            const xnn_simd_f16_t verepo = xnn_fmadd_f16(vrepo, vepo, vminus_one);
            vrepo = xnn_fnmadd_f16(vrepo, verepo, vrepo);

          xnn_simd_f16_t vy = xnn_mul_f16(vemo, vrepo);

          $if DIV.endswith("ADJ"):
            const xnn_simd_f16_t vey = xnn_fnmadd_f16(vy, vepo, vemo);
            vy = xnn_fmadd_f16(vey, vrepo, vy);

        vy = xnn_xor_f16(vy, xnn_and_f16(xnn_xor_f16(vx, vy), vsign_mask));
        xnn_store_tail_f16(o, vy, batch >> XNN_LOG2_SIZEOF_FLOAT16);
      }
  }
