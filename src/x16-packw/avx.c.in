$assert NR >= 8
$assert NR % 8 == 0
$assert KBLOCK == 16

#include <assert.h>
#include <stddef.h>
#include <stdint.h>
#include <string.h>

#include <immintrin.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/intrinsics-polyfill.h"
#include "src/xnnpack/packw.h"
#include "src/xnnpack/unaligned.h"
$if PREFETCH:
  #include "src/xnnpack/prefetch.h"


void xnn_x16_packw_gemm_goi_ukernel_x${NR}__avx2_u${KBLOCK}${"_prfm" if PREFETCH else ""}(
  size_t g,
  size_t nc,
  size_t kc,
  size_t nr,
  size_t kr,
  size_t sr,
  const uint16_t* weights,
  const uint16_t* bias,
  const void* scale,
  uint16_t* packed_weights,
  size_t extra_bytes,
  const void* params)
{
  assert(g != 0);
  assert(nc != 0);
  assert(kc != 0);
  assert(nr == ${NR});   // This kernel is for NR=${NR}
  assert(kr == 1);
  assert(sr == 1);
  assert(weights != NULL);
  assert(packed_weights != NULL);

  const uint16_t* b = bias;
  uint16_t* packed_w = packed_weights;
  do {
    // NC main loop multiple of ${NR}
    const uint16_t* w0 = weights;
    size_t n = nc;

    for (; n >= ${NR}; n -= ${NR}) {
      if XNN_LIKELY(b != NULL) {
        $for N in range(0, NR, 8):
          const __m128i vb${N} = _mm_loadu_si128((const __m128i*) (b + ${N}));
          _mm_storeu_si128((__m128i*) (packed_w + ${N}), vb${N});
        b += ${NR};
      } else {
        const __m128i vzero = _mm_setzero_si128();
        $for N in range(0, NR, 8):
          _mm_storeu_si128((__m128i*) (packed_w + ${N}), vzero);
      }
      packed_w += ${NR};

      $for N in range(1, NR):
        const uint16_t* w${N} = w${N-1} + kc;
      $if PREFETCH:
        $for N in range(0, NR):
          xnn_prefetch_to_l1((const int8_t*) w${N});
          xnn_prefetch_to_l1((const int8_t*) w${N} + 64);

      // KC main loop multiple of ${KBLOCK}
      size_t k = kc;
      for (; k >= ${KBLOCK}; k -= ${KBLOCK}) {
        $for N in range(0, NR, 8):
          $for L in range(8):
            __m256i v${N+L} = _mm256_loadu_si256((const __m256i*) w${N+L});
            w${N+L} += ${KBLOCK};

        $for N in range(0, NR, 8):
          $for L in range(0, 8, 2):
            const __m256i t${N+L} = _mm256_unpacklo_epi16(v${N+L}, v${N+L+1});
            const __m256i t${N+L+1} = _mm256_unpackhi_epi16(v${N+L}, v${N+L+1});

          $for L in range(0, 8, 4):
            const __m256i u${N+L} = _mm256_unpacklo_epi32(t${N+L}, t${N+L+2});
            const __m256i u${N+L+1} = _mm256_unpackhi_epi32(t${N+L}, t${N+L+2});
            const __m256i u${N+L+2} = _mm256_unpacklo_epi32(t${N+L+1}, t${N+L+3});
            const __m256i u${N+L+3} = _mm256_unpackhi_epi32(t${N+L+1}, t${N+L+3});

          const __m256i w${N+0} = _mm256_unpacklo_epi64(u${N+0}, u${N+4});
          const __m256i w${N+1} = _mm256_unpackhi_epi64(u${N+0}, u${N+4});
          const __m256i w${N+2} = _mm256_unpacklo_epi64(u${N+1}, u${N+5});
          const __m256i w${N+3} = _mm256_unpackhi_epi64(u${N+1}, u${N+5});
          const __m256i w${N+4} = _mm256_unpacklo_epi64(u${N+2}, u${N+6});
          const __m256i w${N+5} = _mm256_unpackhi_epi64(u${N+2}, u${N+6});
          const __m256i w${N+6} = _mm256_unpacklo_epi64(u${N+3}, u${N+7});
          const __m256i w${N+7} = _mm256_unpackhi_epi64(u${N+3}, u${N+7});

        $for K in range(8):
          $for N in range(0, NR, 8):
            _mm_storeu_si128((__m128i*) (packed_w + ${N + K*NR}), _mm256_castsi256_si128(w${N+K}));
            _mm_storeu_si128((__m128i*) (packed_w + ${N + (K+8)*NR}), _mm256_extracti128_si256(w${N+K}, 1));
        packed_w += ${NR * KBLOCK};
      }

      // KC remainder (1..15)
      if XNN_UNLIKELY(k != 0) {
        assert(k >= 1);
        assert(k <= 15);

        if (k & 8) {
          $for N in range(0, NR, 8):
            $for L in range(8):
              __m256i v${N+L} = _mm256_castsi128_si256(_mm_loadu_si128((const __m128i*) w${N+L}));
              w${N+L} += 8;

          $for N in range(0, NR, 8):
            $for L in range(0, 8, 2):
              const __m256i t${N+L} = _mm256_unpacklo_epi16(v${N+L}, v${N+L+1});
              const __m256i t${N+L+1} = _mm256_unpackhi_epi16(v${N+L}, v${N+L+1});

            $for L in range(0, 8, 4):
              const __m256i u${N+L} = _mm256_unpacklo_epi32(t${N+L}, t${N+L+2});
              const __m256i u${N+L+1} = _mm256_unpackhi_epi32(t${N+L}, t${N+L+2});
              const __m256i u${N+L+2} = _mm256_unpacklo_epi32(t${N+L+1}, t${N+L+3});
              const __m256i u${N+L+3} = _mm256_unpackhi_epi32(t${N+L+1}, t${N+L+3});

            const __m256i w${N+0} = _mm256_unpacklo_epi64(u${N+0}, u${N+4});
            const __m256i w${N+1} = _mm256_unpackhi_epi64(u${N+0}, u${N+4});
            const __m256i w${N+2} = _mm256_unpacklo_epi64(u${N+1}, u${N+5});
            const __m256i w${N+3} = _mm256_unpackhi_epi64(u${N+1}, u${N+5});
            const __m256i w${N+4} = _mm256_unpacklo_epi64(u${N+2}, u${N+6});
            const __m256i w${N+5} = _mm256_unpackhi_epi64(u${N+2}, u${N+6});
            const __m256i w${N+6} = _mm256_unpacklo_epi64(u${N+3}, u${N+7});
            const __m256i w${N+7} = _mm256_unpackhi_epi64(u${N+3}, u${N+7});

          $for K in range(8):
            $for N in range(0, NR, 8):
              _mm_storeu_si128((__m128i*) (packed_w + ${N + K*NR}), _mm256_castsi256_si128(w${N+K}));
          packed_w += ${NR * 8};
        }

        if (k & 4) {
          $for N in range(0, NR, 8):
            $for L in range(8):
              __m256i v${N+L} = _mm256_castsi128_si256(_mm_loadl_epi64((const __m128i*) w${N+L}));
              w${N+L} += 4;

          $for N in range(0, NR, 8):
            $for L in range(0, 8, 2):
              const __m256i t${N+L} = _mm256_unpacklo_epi16(v${N+L}, v${N+L+1});

            $for L in range(0, 8, 4):
              const __m256i u${N+L} = _mm256_unpacklo_epi32(t${N+L}, t${N+L+2});
              const __m256i u${N+L+1} = _mm256_unpackhi_epi32(t${N+L}, t${N+L+2});

            const __m256i w${N+0} = _mm256_unpacklo_epi64(u${N+0}, u${N+4});
            const __m256i w${N+1} = _mm256_unpackhi_epi64(u${N+0}, u${N+4});
            const __m256i w${N+2} = _mm256_unpacklo_epi64(u${N+1}, u${N+5});
            const __m256i w${N+3} = _mm256_unpackhi_epi64(u${N+1}, u${N+5});

          $for K in range(4):
            $for N in range(0, NR, 8):
              _mm_storeu_si128((__m128i*) (packed_w + ${N + K*NR}), _mm256_castsi256_si128(w${N+K}));
          packed_w += ${NR * 4};
        }

        if (k & 2) {
          $for N in range(0, NR, 8):
            $for L in range(8):
              __m256i v${N+L} = _mm256_castsi128_si256(_mm_cvtsi32_si128((int) unaligned_load_u32(w${N+L})));
              w${N+L} += 2;

          $for N in range(0, NR, 8):
            $for L in range(0, 8, 2):
              const __m256i t${N+L} = _mm256_unpacklo_epi16(v${N+L}, v${N+L+1});

            $for L in range(0, 8, 4):
              const __m256i u${N+L} = _mm256_unpacklo_epi32(t${N+L}, t${N+L+2});

            const __m256i w${N+0} = _mm256_unpacklo_epi64(u${N+0}, u${N+4});
            const __m256i w${N+1} = _mm256_unpackhi_epi64(u${N+0}, u${N+4});

          $for K in range(2):
            $for N in range(0, NR, 8):
              _mm_storeu_si128((__m128i*) (packed_w + ${N + K*NR}), _mm256_castsi256_si128(w${N+K}));
          packed_w += ${NR * 2};
        }

        if (k & 1) {
          $for N in range(0, NR, 8):
            $for L in range(8):
              __m256i v${N+L} = _mm256_castsi128_si256(_mm_insert_epi16(_mm_setzero_si128(), *w${N+L}, 0));
              w${N+L} += 1;

          $for N in range(0, NR, 8):
            $for L in range(0, 8, 2):
              const __m256i t${N+L} = _mm256_unpacklo_epi16(v${N+L}, v${N+L+1});

            $for L in range(0, 8, 4):
              const __m256i u${N+L} = _mm256_unpacklo_epi32(t${N+L}, t${N+L+2});

            const __m256i w${N+0} = _mm256_unpacklo_epi64(u${N+0}, u${N+4});

          $for K in range(1):
            $for N in range(0, NR, 8):
              _mm_storeu_si128((__m128i*) (packed_w + ${N + K*NR}), _mm256_castsi256_si128(w${N+K}));
          packed_w += ${NR * 1};
        }
      }
      packed_w = (uint16_t*) ((uintptr_t) packed_w + extra_bytes);
      w0 = w${NR-1};
    }

    // NC remainder (1..${NR-1})
    if XNN_UNLIKELY(n != 0) {
      assert(n >= 1);
      assert(n <= ${NR-1});
      if XNN_LIKELY(b != NULL) {
        size_t nb = n;
        do {
          *packed_w++ = *b++;
        } while (--nb != 0);
        packed_w += (${NR} - n);
      } else {
        const __m128i vzero = _mm_setzero_si128();
        $for N in range(0, NR, 8):
          _mm_storeu_si128((__m128i*) (packed_w + ${N}), vzero);
        packed_w += ${NR};
      }

      // NR remainder has less than ${NR} rows so last row is not loaded
      $for N in range(1, NR-1):
        const uint16_t* w${N} = w${N-1} + kc;
        $if N % 2 == 0:
          if XNN_UNPREDICTABLE(n <= ${N}) {
            w${N} = w${N-1};
          }
        $else:
          if XNN_UNPREDICTABLE(n < ${N+1}) {
            w${N} = w${N-1};
          }

      // KC main loop multiple of ${KBLOCK}
      size_t k = kc;
      for (; k >= ${KBLOCK}; k -= ${KBLOCK}) {
        $for N in range(0, NR, 8):
          $for L in range(8):
            $if N+L == NR-1:
              __m256i v${N+L} = _mm256_setzero_si256();
            $else:
              __m256i v${N+L} = _mm256_loadu_si256((const __m256i*) w${N+L});
              w${N+L} += ${KBLOCK};

        $for N in range(0, NR, 8):
          $for L in range(0, 8, 2):
            const __m256i t${N+L} = _mm256_unpacklo_epi16(v${N+L}, v${N+L+1});
            const __m256i t${N+L+1} = _mm256_unpackhi_epi16(v${N+L}, v${N+L+1});

          $for L in range(0, 8, 4):
            const __m256i u${N+L} = _mm256_unpacklo_epi32(t${N+L}, t${N+L+2});
            const __m256i u${N+L+1} = _mm256_unpackhi_epi32(t${N+L}, t${N+L+2});
            const __m256i u${N+L+2} = _mm256_unpacklo_epi32(t${N+L+1}, t${N+L+3});
            const __m256i u${N+L+3} = _mm256_unpackhi_epi32(t${N+L+1}, t${N+L+3});

          const __m256i w${N+0} = _mm256_unpacklo_epi64(u${N+0}, u${N+4});
          const __m256i w${N+1} = _mm256_unpackhi_epi64(u${N+0}, u${N+4});
          const __m256i w${N+2} = _mm256_unpacklo_epi64(u${N+1}, u${N+5});
          const __m256i w${N+3} = _mm256_unpackhi_epi64(u${N+1}, u${N+5});
          const __m256i w${N+4} = _mm256_unpacklo_epi64(u${N+2}, u${N+6});
          const __m256i w${N+5} = _mm256_unpackhi_epi64(u${N+2}, u${N+6});
          const __m256i w${N+6} = _mm256_unpacklo_epi64(u${N+3}, u${N+7});
          const __m256i w${N+7} = _mm256_unpackhi_epi64(u${N+3}, u${N+7});

        $for K in range(8):
          $for N in range(0, NR, 8):
            _mm_storeu_si128((__m128i*) (packed_w + ${N + K*NR}), _mm256_castsi256_si128(w${N+K}));
            _mm_storeu_si128((__m128i*) (packed_w + ${N + (K+8)*NR}), _mm256_extracti128_si256(w${N+K}, 1));
        packed_w += ${NR * KBLOCK};
      }

      // KC remainder (1..15)
      if XNN_UNLIKELY(k != 0) {
        assert(k >= 1);
        assert(k <= 15);

        if (k & 8) {
          $for N in range(0, NR, 8):
            $for L in range(8):
              $if N+L == NR-1:
                __m256i v${N+L} = _mm256_setzero_si256();
              $else:
                __m256i v${N+L} = _mm256_castsi128_si256(_mm_loadu_si128((const __m128i*) w${N+L}));
                w${N+L} += 8;

          $for N in range(0, NR, 8):
            $for L in range(0, 8, 2):
              const __m256i t${N+L} = _mm256_unpacklo_epi16(v${N+L}, v${N+L+1});
              const __m256i t${N+L+1} = _mm256_unpackhi_epi16(v${N+L}, v${N+L+1});

            $for L in range(0, 8, 4):
              const __m256i u${N+L} = _mm256_unpacklo_epi32(t${N+L}, t${N+L+2});
              const __m256i u${N+L+1} = _mm256_unpackhi_epi32(t${N+L}, t${N+L+2});
              const __m256i u${N+L+2} = _mm256_unpacklo_epi32(t${N+L+1}, t${N+L+3});
              const __m256i u${N+L+3} = _mm256_unpackhi_epi32(t${N+L+1}, t${N+L+3});

            const __m256i w${N+0} = _mm256_unpacklo_epi64(u${N+0}, u${N+4});
            const __m256i w${N+1} = _mm256_unpackhi_epi64(u${N+0}, u${N+4});
            const __m256i w${N+2} = _mm256_unpacklo_epi64(u${N+1}, u${N+5});
            const __m256i w${N+3} = _mm256_unpackhi_epi64(u${N+1}, u${N+5});
            const __m256i w${N+4} = _mm256_unpacklo_epi64(u${N+2}, u${N+6});
            const __m256i w${N+5} = _mm256_unpackhi_epi64(u${N+2}, u${N+6});
            const __m256i w${N+6} = _mm256_unpacklo_epi64(u${N+3}, u${N+7});
            const __m256i w${N+7} = _mm256_unpackhi_epi64(u${N+3}, u${N+7});

          $for K in range(8):
            $for N in range(0, NR, 8):
              _mm_storeu_si128((__m128i*) (packed_w + ${N + K*NR}), _mm256_castsi256_si128(w${N+K}));
          packed_w += ${NR * 8};
        }

        if (k & 4) {
          $for N in range(0, NR, 8):
            $for L in range(8):
              $if N+L == NR-1:
                __m256i v${N+L} = _mm256_setzero_si256();
              $else:
                __m256i v${N+L} = _mm256_castsi128_si256(_mm_loadl_epi64((const __m128i*) w${N+L}));
                w${N+L} += 4;

          $for N in range(0, NR, 8):
            $for L in range(0, 8, 2):
              const __m256i t${N+L} = _mm256_unpacklo_epi16(v${N+L}, v${N+L+1});

            $for L in range(0, 8, 4):
              const __m256i u${N+L} = _mm256_unpacklo_epi32(t${N+L}, t${N+L+2});
              const __m256i u${N+L+1} = _mm256_unpackhi_epi32(t${N+L}, t${N+L+2});

            const __m256i w${N+0} = _mm256_unpacklo_epi64(u${N+0}, u${N+4});
            const __m256i w${N+1} = _mm256_unpackhi_epi64(u${N+0}, u${N+4});
            const __m256i w${N+2} = _mm256_unpacklo_epi64(u${N+1}, u${N+5});
            const __m256i w${N+3} = _mm256_unpackhi_epi64(u${N+1}, u${N+5});

          $for K in range(4):
            $for N in range(0, NR, 8):
              _mm_storeu_si128((__m128i*) (packed_w + ${N + K*NR}), _mm256_castsi256_si128(w${N+K}));
          packed_w += ${NR * 4};
        }

        if (k & 2) {
          $for N in range(0, NR, 8):
            $for L in range(8):
              $if N+L == NR-1:
                __m256i v${N+L} = _mm256_setzero_si256();
              $else:
                __m256i v${N+L} = _mm256_castsi128_si256(_mm_cvtsi32_si128((int) unaligned_load_u32(w${N+L})));
                w${N+L} += 2;

          $for N in range(0, NR, 8):
            $for L in range(0, 8, 2):
              const __m256i t${N+L} = _mm256_unpacklo_epi16(v${N+L}, v${N+L+1});

            $for L in range(0, 8, 4):
              const __m256i u${N+L} = _mm256_unpacklo_epi32(t${N+L}, t${N+L+2});

            const __m256i w${N+0} = _mm256_unpacklo_epi64(u${N+0}, u${N+4});
            const __m256i w${N+1} = _mm256_unpackhi_epi64(u${N+0}, u${N+4});

          $for K in range(2):
            $for N in range(0, NR, 8):
              _mm_storeu_si128((__m128i*) (packed_w + ${N + K*NR}), _mm256_castsi256_si128(w${N+K}));
          packed_w += ${NR * 2};
        }

        if (k & 1) {
          $for N in range(0, NR, 8):
            $for L in range(8):
              $if N+L == NR-1:
                __m256i v${N+L} = _mm256_setzero_si256();
              $else:
                __m256i v${N+L} = _mm256_castsi128_si256(_mm_insert_epi16(_mm_setzero_si128(), *w${N+L}, 0));
                w${N+L} += 1;

          $for N in range(0, NR, 8):
            $for L in range(0, 8, 2):
              const __m256i t${N+L} = _mm256_unpacklo_epi16(v${N+L}, v${N+L+1});

            $for L in range(0, 8, 4):
              const __m256i u${N+L} = _mm256_unpacklo_epi32(t${N+L}, t${N+L+2});

            const __m256i w${N+0} = _mm256_unpacklo_epi64(u${N+0}, u${N+4});

          $for K in range(1):
            $for N in range(0, NR, 8):
              _mm_storeu_si128((__m128i*) (packed_w + ${N + K*NR}), _mm256_castsi256_si128(w${N+K}));
          packed_w += ${NR * 1};
        }
      }
      packed_w = (uint16_t*) ((uintptr_t) packed_w + extra_bytes);
    }
    weights += nc * kc;
  } while (--g != 0);
}
