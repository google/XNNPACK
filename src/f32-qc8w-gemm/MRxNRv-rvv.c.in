$assert ACTIVATION in ["LINEAR", "MINMAX"]
$assert MR >= 1
$assert NR in ["m1", "m2", "m4", "m8"]
$LMUL = NR[1]
$I8_LMUL = {"1": "mf4", "2": "mf2", "4": "m1", "8": "m2"}[LMUL]
$I16_LMUL = {"1": "mf2", "2": "m1", "4": "m2", "8": "m4"}[LMUL]
#include <assert.h>
#include <stddef.h>
#include <stdint.h>

#include <riscv_vector.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/gemm.h"


$SUFFIX = {"LINEAR": "", "MINMAX": "_minmax"}[ACTIVATION]
$PARAMS = {"LINEAR": "struct xnn_f32_default_params", "MINMAX": "struct xnn_f32_minmax_params"}[ACTIVATION]
void xnn_f32_qc8w_gemm${SUFFIX}_ukernel_${MR}x${LMUL}v__rvv(
    size_t mr,
    size_t nc,
    size_t kc,
    const float* restrict a,
    size_t a_stride,
    const void* restrict w,
    float* restrict c,
    size_t cm_stride,
    size_t cn_stride,
    const ${PARAMS}* restrict params)
{
  assert(mr != 0);
  assert(mr <= ${MR});
  assert(nc != 0);
  assert(kc != 0);
  assert(kc % sizeof(float) == 0);
  assert(a != NULL);
  assert(w != NULL);
  assert(c != NULL);

  $if ACTIVATION == "MINMAX":
    const float vmin = params->scalar.min;
    const float vmax = params->scalar.max;
  const float* a0 = a;
  float* c0 = c;
  $for M in range(1, MR):
    const float* a${M} = (const float*) ((uintptr_t) a${M-1} + a_stride);
    float* c${M} = (float*) ((uintptr_t) c${M-1} + cm_stride);
    $if M % 2 == 0:
      if XNN_UNPREDICTABLE(mr <= ${M}) {
        a${M} = a${M-1};
        c${M} = c${M-1};
      }
    $elif M + 1 == MR:
      if XNN_UNPREDICTABLE(mr != ${M+1}) {
        a${M} = a${M-1};
        c${M} = c${M-1};
      }
    $else:
      if XNN_UNPREDICTABLE(mr < ${M+1}) {
        a${M} = a${M-1};
        c${M} = c${M-1};
      }

  const size_t nr = __riscv_vsetvlmax_e32m${LMUL}();
  size_t vl = nr;
  do {
    if XNN_UNLIKELY(nc < nr) {
      vl = __riscv_vsetvl_e32m${LMUL}(nc);
    }
    nc -= vl;

    // Load bias (float).
    vfloat32m${LMUL}_t vacc0 = __riscv_vle32_v_f32m${LMUL}((const float*) w, vl);
    w = (const float*) w + nr;
    $for M in range(1, MR):
      vfloat32m${LMUL}_t vacc${M} = __riscv_vmv_v_v_f32m${LMUL}(vacc0, vl);

    // Inner loop: accumulate int8 weights * float activations.
    size_t k = kc;
    do {
      $for M in range(MR):
        const float va${M} = *a${M}++;

      // Load int8 weights and widen to int32, then convert to float.
      vint8${I8_LMUL}_t vb_i8 = __riscv_vle8_v_i8${I8_LMUL}((const int8_t*) w, vl);
      w = (const int8_t*) w + nr;
      vint16${I16_LMUL}_t vb_i16 = __riscv_vsext_vf2_i16${I16_LMUL}(vb_i8, vl);
      vint32m${LMUL}_t vb_i32 = __riscv_vsext_vf2_i32m${LMUL}(vb_i16, vl);
      vfloat32m${LMUL}_t vb = __riscv_vfcvt_f_x_v_f32m${LMUL}(vb_i32, vl);

      $for M in range(MR):
        vacc${M} = __riscv_vfmacc_vf_f32m${LMUL}(vacc${M}, va${M}, vb, vl);

      k -= sizeof(float);
    } while (k != 0);

    // Load per-channel scales and apply.
    vfloat32m${LMUL}_t vscale = __riscv_vle32_v_f32m${LMUL}((const float*) w, vl);
    w = (const float*) w + nr;
    $for M in range(MR):
      vacc${M} = __riscv_vfmul_vv_f32m${LMUL}(vacc${M}, vscale, vl);

    $if ACTIVATION == "MINMAX":
      // Clamp results.
      $for M in range(MR):
        vacc${M} = __riscv_vfmax_vf_f32m${LMUL}(vacc${M}, vmin, vl);
      $for M in range(MR):
        vacc${M} = __riscv_vfmin_vf_f32m${LMUL}(vacc${M}, vmax, vl);

    // Store results.
    $for M in range(MR):
      __riscv_vse32_v_f32m${LMUL}(c${M}, vacc${M}, vl);
      c${M} = (float*) ((uintptr_t) c${M} + cn_stride);
    $for M in range(MR):
      a${M} = (const float*) ((uintptr_t) a${M} - kc);
  } while (nc != 0);
}
